#!/usr/bin/env ruby
# frozen_string_literal: true

# Decide whether a PR's CI is ready, without writing to git or GitHub.
#
# Encapsulates the repeated "is this PR's CI ready?" rule that is otherwise
# restated in prose across pr-batch, adversarial-pr-review, and pr-processing:
#
#   1. Run `gh pr checks <PR> --required`. If it reports no current required
#      checks -- either no JSON at all, or only cancelled rows -- fall back to
#      the full `gh pr checks <PR>` list while retaining required cancellations.
#   2. No current rows or retained required cancellations => UNKNOWN / not ready.
#   3. A required cancellation blocks as pending unless a non-cancel row with
#      the same workflow and name proves supersession. Ignore other cancelled
#      rows from the full advisory list.
#   4. Otherwise READY only when no failing (bucket "fail") and no pending
#      (bucket "pending") rows remain. Passing and skipping rows are fine.
#   5. Inventory current-head PENDING review drafts visible to the current
#      authenticated viewer. READY requires a complete viewer-scoped inventory
#      with no drafts; other reviewers' unsubmitted drafts are not observable
#      or covered, and an unavailable inventory is UNKNOWN.
#
# `gh pr checks` exits non-zero when checks are failing or pending, so this
# captures stdout and inspects the rows rather than trusting the exit status.
#
# Requires: gh (GitHub CLI). Ruby stdlib only.

require "json"
require "open3"

# Pure verdict logic (no I/O) plus the gh-backed runner. The pure methods take
# the raw `gh pr checks --json` output string (or parsed rows) so they can be
# unit-tested directly without a subprocess.
module PrCiReadiness
  class Error < StandardError; end

  module_function

  # Parse a `gh pr checks --json name,state,bucket,link,workflow` payload into rows.
  # Blank or non-JSON input (e.g. gh's "no required checks" message) yields [].
  def parse_rows(raw)
    return [] if raw.nil? || raw.strip.empty?

    rows = JSON.parse(raw)
    rows.is_a?(Array) ? rows : []
  rescue JSON::ParserError
    []
  end

  def json_array_payload?(raw)
    JSON.parse(raw.to_s).is_a?(Array)
  rescue JSON::ParserError
    false
  end

  # True when the raw payload holds a JSON array with at least one current row.
  # A required-check list made up entirely of cancelled rows still falls back
  # so the full list can supply same-context supersession evidence.
  def usable_checks?(raw)
    !active_rows(parse_rows(raw)).empty?
  end

  # Current rows that count toward a full/advisory gate. Required cancellations
  # are reconciled separately so unrelated cancelled advisory noise stays out.
  def active_rows(rows)
    rows.reject { |row| row["bucket"].to_s == "cancel" }
  end

  def check_identity(row)
    [row["workflow"].to_s, row["name"].to_s]
  end

  # Preserve required cancellations unless a current row with the exact same
  # workflow/name identity supersedes them. Full-list cancellations are noise.
  def readiness_rows(rows, required_used:, required_cancellations: [])
    current_rows = active_rows(rows)
    gate_rows = required_used ? rows : current_rows + required_cancellations
    current_contexts = current_rows.map { |row| check_identity(row) }
    gate_rows.reject do |row|
      row["bucket"].to_s == "cancel" && current_contexts.include?(check_identity(row))
    end
  end

  def failing_names(rows)
    rows.select { |row| row["bucket"].to_s == "fail" }.map { |row| row["name"].to_s }
  end

  def pending_names(rows)
    rows.select { |row| %w[cancel pending].include?(row["bucket"].to_s) }.map { |row| row["name"].to_s }
  end

  def verdict_for(rows, failing, pending)
    if rows.empty?
      "UNKNOWN"
    elsif failing.empty? && pending.empty?
      "READY"
    else
      "NOT_READY"
    end
  end

  # Build the normalized result hash from the captured check rows.
  def assess(pr_number:, required_used:, rows:, required_cancellations: [])
    rows = readiness_rows(rows, required_used:, required_cancellations:)
    failing = failing_names(rows)
    pending = pending_names(rows)

    {
      "pr" => pr_number.to_i,
      "verdict" => verdict_for(rows, failing, pending),
      "required_used" => required_used,
      "failing" => failing,
      "pending" => pending
    }
  end

  def text_summary(result)
    failing = result["failing"]
    pending = result["pending"]
    lines = [
      result["verdict"],
      "required_used: #{result['required_used']}",
      "failing: #{failing.empty? ? '(none)' : failing.join(', ')}",
      "pending: #{pending.empty? ? '(none)' : pending.join(', ')}"
    ]
    requested = result.fetch("requested_hosted", {})
    if requested_hosted_present?(requested)
      lines.concat([
                     "requested_hosted_pending: #{requested_names(requested, 'pending')}",
                     "requested_hosted_failing: #{requested_names(requested, 'failing')}",
                     "requested_hosted_stale: #{requested_names(requested, 'stale')}",
                     "requested_hosted_unknown: #{requested_unknown(requested)}"
                   ])
    end
    reviews = result.fetch("viewer_pending_review_drafts", [])
    lines << "viewer_pending_review_drafts: #{reviews.empty? ? '(none)' : reviews.map { |review| review['id'] }.join(', ')}" if result.key?("viewer_pending_review_drafts")
    inventory = result["viewer_review_inventory"]
    lines << "viewer_review_inventory: #{inventory['complete'] ? 'complete' : 'incomplete'} (scope: #{inventory['scope']})" if inventory
    lines.join("\n")
  end

  def requested_hosted_present?(requested)
    %w[run_ids pending failing stale unknown].any? { |bucket| requested.fetch(bucket, []).any? }
  end

  def requested_names(requested, bucket)
    rows = requested.fetch(bucket, [])
    return "(none)" if rows.empty?

    rows.map { |row| row.fetch("name", row.fetch("run_id", "unknown")).to_s }.join(", ")
  end

  def requested_unknown(requested)
    rows = requested.fetch("unknown", [])
    return "(none)" if rows.empty?

    rows.map { |row| "#{row.fetch('run_id', 'unknown')}: #{row.fetch('reason', 'unknown')}" }.join(", ")
  end

  USAGE = <<~USAGE
    Usage: pr-ci-readiness <pr-number> [options]

    Decide whether a PR's CI is ready to merge. Runs `gh pr checks <PR> --required`
    first; when no current required checks exist (no rows, or only cancelled rows),
    falls back to the full `gh pr checks <PR>` list. Required cancellations remain
    pending unless a current check with the same workflow and name supersedes them.
    Cancelled rows found only in the full advisory list are ignored. A truly empty
    required and full check list is UNKNOWN/not-ready. An unavailable check-query
    capability is also UNKNOWN and cannot be overridden by requested hosted runs.
    The PR is READY only when no failing or pending checks remain.
    Current-head PENDING review drafts visible to the current authenticated
    viewer also block readiness. The viewer-scoped inventory is paginated;
    complete means pagination completed only in that scope. Other reviewers'
    unsubmitted drafts are not observable or covered.

    Arguments:
      <pr-number>        PR number to inspect (integer).

    Options:
          --repo REPO                         GitHub repo in OWNER/REPO form. Defaults to gh repo view.
          --requested-hosted-run RUN_ID_OR_URL
                                              Require this explicit current-head hosted run to finish.
                                              Repeat for multiple maintainer-requested runs.
                                              With no usable required checks, requested runs replace
                                              the full advisory-list fallback gate.
          --json                              Print JSON (default).
          --text                              Print a human-readable verdict instead of JSON.
          --self-check                        Run parser checks plus a read-only gh smoke check.
      -h, --help                              Show this help.

    Output JSON shape:
      {
        "pr": 1234,
        "verdict": "READY" | "NOT_READY" | "UNKNOWN",
        "required_used": true | false,
        "failing": [ "check name", ... ],
        "pending": [ "check name", ... ],
        "viewer_pending_review_drafts": [ { "id": "PRR_...", "commit_oid": "..." }, ... ],
        "viewer_review_inventory": {
          "scope": "authenticated_viewer",
          "complete": true | false,
          "pages": 1
        },
        "requested_hosted": {
          "run_ids": [ "1234567890", ... ],
          "pending": [ { "run_id": "1234567890", "name": "job", "url": "..." }, ... ],
          "failing": [ { "run_id": "1234567890", "name": "job", "url": "..." }, ... ],
          "stale": [ { "run_id": "1234567890", "head_sha": "old", "expected_head_sha": "new" }, ... ],
          "unknown": [ { "run_id": "1234567890", "reason": "..." }, ... ]
        }
      }

    verdict is UNKNOWN when neither check list supplies current rows or retained
    required cancellation evidence. required_used is true when current required
    rows were used directly; it remains false after full-list fallback even when a
    required cancellation remains blocking evidence.
    With --requested-hosted-run and no usable required checks, the requested
    current-head runs are the gate instead of the full advisory check list.

    Requires: gh (GitHub CLI)
  USAGE

  # gh-backed CLI: parses args, fetches the check rows, and prints the verdict.
  # All subprocess calls use array args (no shell).
  class Runner
    def run(argv)
      opts = parse_args(argv)
      if opts[:help]
        puts USAGE
        return 0
      end
      return self_check if opts[:self_check]

      pr_number = validate_pr!(opts[:pr])
      repo = resolve_repo!(opts[:repo])
      print_result(assess(repo, pr_number, requested_hosted_runs: opts[:requested_hosted_runs]), opts[:format])
      0
    rescue Error => e
      warn "Error: #{e.message}"
      1
    end

    private

    def parse_args(argv)
      opts = { format: "json", help: false, self_check: false, pr: nil, repo: nil, requested_hosted_runs: [] }
      args = argv.dup
      until args.empty?
        arg = args.shift
        case arg
        when "--repo" then opts[:repo] = take_value!(args, "--repo")
        when "--requested-hosted-run" then opts[:requested_hosted_runs] << take_value!(args, "--requested-hosted-run")
        when "--json" then opts[:format] = "json"
        when "--text" then opts[:format] = "text"
        when "--self-check" then opts[:self_check] = true
        when "-h", "--help" then opts[:help] = true
        when "--" then nil
        else handle_positional(arg, opts)
        end
      end
      opts
    end

    def handle_positional(arg, opts)
      raise Error, "unknown option: #{arg}\n\n#{USAGE}" if arg.start_with?("-")
      raise Error, "unexpected extra argument: #{arg}" unless opts[:pr].nil?

      opts[:pr] = arg
    end

    def take_value!(args, flag)
      raise Error, "#{flag} requires a value" if args.empty?

      args.shift
    end

    def validate_pr!(pr_number)
      raise Error, "a positive integer PR number is required\n\n#{USAGE}" unless pr_number.to_s.match?(/\A[1-9]\d*\z/)

      pr_number
    end

    # Strict OWNER/REPO: non-empty owner and name, exactly one slash, no spaces.
    REPO_FORMAT = %r{\A[^/\s]+/[^/\s]+\z}

    def resolve_repo!(repo)
      repo ||= capture_required!("gh", "repo", "view", "--json", "nameWithOwner", "-q", ".nameWithOwner").strip
      raise Error, "--repo must be in OWNER/REPO form (got: '#{repo}')" unless repo.match?(REPO_FORMAT)

      repo
    end

    # Fetch the required-check list first; fall back to the full list when the
    # required form yields no current rows. required_used flips false on fallback.
    def assess(repo, pr_number, requested_hosted_runs:)
      required_fetch = fetch_checks(repo, pr_number, required: true)
      required_raw = required_fetch.fetch(:raw)
      required_query_known = required_fetch.fetch(:known_good)
      full_query_known = nil
      required_rows = PrCiReadiness.parse_rows(required_raw)
      required_cancellations = required_rows.select { |row| row["bucket"].to_s == "cancel" }
      if PrCiReadiness.usable_checks?(required_raw)
        rows = required_rows
        required_used = true
        requested_hosted_only = false
      elsif requested_hosted_runs.any?
        rows = []
        required_used = false
        requested_hosted_only = true
        if required_cancellations.any?
          full_fetch = fetch_checks(repo, pr_number, required: false)
          full_rows = PrCiReadiness.parse_rows(full_fetch.fetch(:raw))
          full_query_known = full_fetch.fetch(:known_good)
          required_contexts = required_cancellations.map { |row| PrCiReadiness.check_identity(row) }
          rows = PrCiReadiness.active_rows(full_rows).select do |row|
            required_contexts.include?(PrCiReadiness.check_identity(row))
          end
        end
      else
        full_fetch = fetch_checks(repo, pr_number, required: false)
        rows = PrCiReadiness.parse_rows(full_fetch.fetch(:raw))
        full_query_known = full_fetch.fetch(:known_good)
        required_used = false
        requested_hosted_only = false
      end
      result =
        if requested_hosted_only && required_cancellations.empty?
          requested_hosted_base_result(pr_number)
        else
          PrCiReadiness.assess(pr_number:, required_used:, rows:, required_cancellations:)
        end
      query_evidence_known = required_query_known && full_query_known != false
      result["verdict"] = "UNKNOWN" if !query_evidence_known && result["verdict"] == "READY"
      result = apply_requested_hosted_runs(result, repo, pr_number, requested_hosted_runs)
      apply_viewer_review_inventory(result, repo, pr_number)
    end

    # `gh pr checks` exits non-zero for ordinary failing/pending checks and when
    # no checks exist. JSON output and the established no-checks diagnostic are
    # therefore known-good; other command/query failures remain distinguishable.
    def fetch_checks(repo, pr_number, required:)
      cmd = ["gh", "pr", "checks", pr_number.to_s, "--repo", repo]
      cmd << "--required" if required
      cmd += ["--json", "name,state,bucket,link,workflow"]
      out, err, status = Open3.capture3(*cmd)
      raw = out.to_s.force_encoding("UTF-8")
      known_good = PrCiReadiness.json_array_payload?(raw) ||
                   status.success? && raw.strip.empty? || no_checks_diagnostic?(err)
      { raw:, known_good: }
    end

    def no_checks_diagnostic?(stderr)
      replacement_occurred = false
      normalized = stderr.to_s.dup.force_encoding(Encoding::UTF_8).scrub do
        replacement_occurred = true
        "\uFFFD"
      end
      return false if replacement_occurred

      normalized.match?(/\Ano (?:required )?checks reported on the '[^\r\n]+' branch(?:\r?\n)?\z/)
    end

    def apply_requested_hosted_runs(result, repo, pr_number, requested_hosted_runs)
      result["requested_hosted"] = empty_requested_hosted
      return result if requested_hosted_runs.empty?

      requested = requested_hosted_summary(repo, pr_number, requested_hosted_runs)
      result["requested_hosted"] = requested
      if requested["pending"].any? || requested["failing"].any?
        result["verdict"] = "NOT_READY"
      elsif result["verdict"] == "READY" && (requested["stale"].any? || requested["unknown"].any?)
        result["verdict"] = "UNKNOWN"
      end
      result
    end

    def empty_requested_hosted
      {
        "run_ids" => [],
        "pending" => [],
        "failing" => [],
        "stale" => [],
        "unknown" => []
      }
    end

    def requested_hosted_base_result(pr_number)
      {
        "pr" => pr_number.to_i,
        "verdict" => "READY",
        "required_used" => false,
        "failing" => [],
        "pending" => []
      }
    end

    def apply_viewer_review_inventory(result, repo, pr_number)
      inventory = viewer_pending_review_draft_inventory(repo, pr_number)
      result["viewer_pending_review_drafts"] = inventory.fetch("viewer_pending_review_drafts")
      result["viewer_review_inventory"] = inventory.reject { |key, _value| key == "viewer_pending_review_drafts" }
      if inventory.fetch("viewer_pending_review_drafts").any?
        result["verdict"] = "NOT_READY"
      elsif !inventory.fetch("complete") && result["verdict"] == "READY"
        result["verdict"] = "UNKNOWN"
      end
      result
    end

    REVIEW_DRAFTS_QUERY = <<~GRAPHQL
      query($owner:String!, $name:String!, $pr:Int!, $endCursor:String) {
        repository(owner:$owner, name:$name) {
          pullRequest(number:$pr) {
            reviews(first:100, after:$endCursor) {
              nodes { id state submittedAt commit { oid } }
              pageInfo { hasNextPage endCursor }
            }
          }
        }
      }
    GRAPHQL

    def viewer_pending_review_draft_inventory(repo, pr_number)
      owner, name = repo.split("/", 2)
      expected_head_sha = fetch_pr_head_oid(repo, pr_number)
      viewer_pending_review_drafts = []
      cursor = nil
      pages = 0

      loop do
        reviews = fetch_reviews_page(owner, name, pr_number, cursor)
        nodes = reviews.fetch("nodes")
        page_info = reviews.fetch("pageInfo")
        raise Error, "review inventory returned non-array nodes" unless nodes.is_a?(Array)
        raise Error, "review inventory returned incomplete page info" unless page_info.is_a?(Hash)

        pending_reviews = nodes.select do |review|
          review["state"] == "PENDING" && review["submittedAt"].nil? &&
            review.dig("commit", "oid") == expected_head_sha
        end
        viewer_pending_review_drafts.concat(pending_reviews.map do |review|
          { "id" => review.fetch("id"), "commit_oid" => expected_head_sha }
        end)
        pages += 1
        break unless page_info["hasNextPage"]

        cursor = page_info["endCursor"]
        raise Error, "review inventory pagination cursor was missing" if cursor.to_s.empty?
      end

      { "scope" => "authenticated_viewer", "complete" => true, "pages" => pages,
        "viewer_pending_review_drafts" => viewer_pending_review_drafts }
    rescue StandardError => e
      { "scope" => "authenticated_viewer", "complete" => false, "pages" => pages || 0,
        "viewer_pending_review_drafts" => viewer_pending_review_drafts || [], "error" => e.message }
    end

    def fetch_reviews_page(owner, name, pr_number, cursor)
      cmd = ["gh", "api", "graphql", "-f", "owner=#{owner}", "-f", "name=#{name}", "-F", "pr=#{pr_number}"]
      cmd += ["-f", "endCursor=#{cursor}"] unless cursor.nil?
      cmd += ["-f", "query=#{REVIEW_DRAFTS_QUERY}"]
      data = capture_json!(*cmd)
      data.dig("data", "repository", "pullRequest", "reviews") ||
        raise(Error, "review inventory response was incomplete")
    end

    def requested_hosted_summary(repo, pr_number, requested_hosted_runs)
      expected_head_sha = fetch_pr_head_oid(repo, pr_number)
      requested_hosted_runs.each_with_object(empty_requested_hosted) do |input, summary|
        run_id = requested_hosted_run_id(input)
        summary["run_ids"] << run_id
        run = fetch_actions_run(repo, run_id)
        classify_requested_run(summary, repo, run_id, run, expected_head_sha)
      rescue Error => e
        summary["unknown"] << { "run_id" => run_id || input.to_s, "reason" => e.message }
      end
    end

    def requested_hosted_run_id(input)
      value = input.to_s.strip
      run_id = value[%r{/actions/runs/(\d+)}, 1] || value[/\A\d+\z/]
      raise Error, "requested hosted run must be a run id or Actions run URL (got: '#{input}')" if run_id.nil?

      run_id
    end

    def classify_requested_run(summary, repo, run_id, run, expected_head_sha)
      actual_head_sha = run.fetch("head_sha", "").to_s
      if actual_head_sha.empty? || actual_head_sha != expected_head_sha
        summary["stale"] << run_record(run_id, run).merge(
          "head_sha" => actual_head_sha,
          "expected_head_sha" => expected_head_sha
        )
        return
      end

      classify_status_row(summary, "run", run_id, run_record(run_id, run))
      return if run.fetch("status", "").to_s == "completed" && successful_conclusion?(run.fetch("conclusion", "").to_s)

      fetch_actions_jobs(repo, run_id).each do |job|
        classify_status_row(summary, "job", run_id, run_record(run_id, job))
      end
    end

    def classify_status_row(summary, kind, run_id, row)
      status = row["status"].to_s
      conclusion = row["conclusion"].to_s
      record = row.merge("kind" => kind, "run_id" => run_id)
      if status != "completed"
        summary["pending"] << record
      elsif successful_conclusion?(conclusion)
        nil
      else
        summary["failing"] << record
      end
    end

    def successful_conclusion?(conclusion)
      %w[success neutral skipped].include?(conclusion)
    end

    def run_record(run_id, payload)
      {
        "run_id" => run_id,
        "name" => payload["name"].to_s.empty? ? "run #{run_id}" : payload["name"].to_s,
        "status" => payload["status"].to_s,
        "conclusion" => payload["conclusion"],
        "url" => payload["html_url"].to_s
      }
    end

    def fetch_pr_head_oid(repo, pr_number)
      data = capture_json!("gh", "pr", "view", pr_number.to_s, "--repo", repo, "--json", "headRefOid")
      head = data.fetch("headRefOid", "").to_s
      raise Error, "could not resolve PR headRefOid for ##{pr_number}" if head.empty?

      head
    end

    def fetch_actions_run(repo, run_id)
      capture_json!("gh", "api", "repos/#{repo}/actions/runs/#{run_id}")
    end

    def fetch_actions_jobs(repo, run_id)
      per_page = 100
      jobs = []
      page = 1
      loop do
        data = capture_json!("gh", "api", "repos/#{repo}/actions/runs/#{run_id}/jobs?per_page=#{per_page}&page=#{page}")
        page_jobs = data.fetch("jobs", [])
        jobs.concat(page_jobs)
        break if page_jobs.length < per_page

        page += 1
      end
      jobs
    end

    def capture_json!(*cmd)
      raw = capture_required!(*cmd)
      JSON.parse(raw)
    rescue JSON::ParserError => e
      raise Error, "command returned invalid JSON: #{cmd.first(3).join(' ')} (#{e.message})"
    end

    # Run a command with no shell (array args) and return UTF-8 stdout, raising
    # when the command fails. Used only for commands whose exit status matters.
    def capture_required!(*cmd)
      out, status = Open3.capture2(*cmd)
      raise Error, "command failed: #{cmd.first(3).join(' ')}" unless status.success?

      out.force_encoding("UTF-8")
    end

    def print_result(result, format)
      if format == "text"
        puts PrCiReadiness.text_summary(result)
      else
        puts JSON.pretty_generate(result)
      end
    end

    def self_check
      errors = self_check_errors
      unless errors.empty?
        warn "self-check failed: #{errors.join('; ')}"
        return 1
      end
      puts "verdict parser: ok"
      puts gh_smoke
      puts "self-check passed"
      0
    end

    # Exercise the pure verdict logic against canned check arrays.
    def self_check_errors
      [
        check_all_passing,
        check_failing,
        check_required_cancellation,
        check_cancel_only,
        check_empty,
        check_parse_helpers
      ].flatten
    end

    def check_all_passing
      out = PrCiReadiness.assess(pr_number: 1, required_used: true, rows: [
                                   { "name" => "rspec", "bucket" => "pass" },
                                   { "name" => "examples", "bucket" => "skipping" }
                                 ])
      ok = out["verdict"] == "READY" && out["required_used"] == true &&
           out["failing"].empty? && out["pending"].empty?
      ok ? [] : ["all-passing did not yield READY"]
    end

    def check_failing
      out = PrCiReadiness.assess(pr_number: 1, required_used: false, rows: [
                                   { "name" => "rspec", "bucket" => "pass" },
                                   { "name" => "lint", "bucket" => "fail" },
                                   { "name" => "stale", "bucket" => "cancel" }
                                 ])
      ok = out["verdict"] == "NOT_READY" && out["failing"] == ["lint"] && out["pending"].empty?
      ok ? [] : ["failing did not yield NOT_READY (lint)"]
    end

    def check_required_cancellation
      out = PrCiReadiness.assess(pr_number: 1, required_used: true, rows: [
                                   { "workflow" => "CI", "name" => "unit", "bucket" => "pass" },
                                   { "workflow" => "Security", "name" => "security", "bucket" => "cancel" }
                                 ])
      ok = out["verdict"] == "NOT_READY" && out["pending"] == ["security"]
      ok ? [] : ["distinct required cancellation did not yield NOT_READY (security)"]
    end

    def check_cancel_only
      out = PrCiReadiness.assess(pr_number: 1, required_used: false,
                                 rows: [{ "name" => "stale", "bucket" => "cancel" }])
      out["verdict"] == "UNKNOWN" ? [] : ["cancel-only did not yield UNKNOWN"]
    end

    def check_empty
      out = PrCiReadiness.assess(pr_number: 1, required_used: false, rows: [])
      out["verdict"] == "UNKNOWN" ? [] : ["empty did not yield UNKNOWN"]
    end

    def check_parse_helpers
      errors = []
      active = PrCiReadiness.usable_checks?('[{"name":"a","bucket":"pass"}]')
      errors << "usable_checks? missed an active array" unless active
      errors << "usable_checks? treated [] as usable" if PrCiReadiness.usable_checks?("[]")
      errors << "usable_checks? treated blank as usable" if PrCiReadiness.usable_checks?("")
      errors << "usable_checks? treated non-JSON as usable" if PrCiReadiness.usable_checks?("no required checks")
      if PrCiReadiness.usable_checks?('[{"name":"stale","bucket":"cancel"}]')
        errors << "usable_checks? treated cancel-only as usable"
      end
      errors
    end

    def gh_smoke
      return "gh smoke: skipped (gh not installed)" unless system("command -v gh > /dev/null 2>&1")

      repo, status = Open3.capture2("gh", "repo", "view", "--json", "nameWithOwner", "-q", ".nameWithOwner")
      return "gh smoke: skipped (gh not authenticated)" unless status.success? && !repo.strip.empty?

      "gh smoke: ok for #{repo.strip}"
    end
  end
end

exit(PrCiReadiness::Runner.new.run(ARGV)) if $PROGRAM_NAME == __FILE__
