#!/usr/bin/env ruby
# frozen_string_literal: true

# Replay machine-readable closeout evidence markers from PR bodies, issue
# comments, or saved handoff files. The visible Markdown remains the operator
# interface; these hidden markers make post-merge audit recovery deterministic.

require "json"
require "optparse"

module CloseoutEvidenceReplay
  module_function

  VALID_QA_STATUSES = %w[satisfied blocked waived in_progress unknown not_applicable].freeze
  VALID_QA_REQUIRED = %w[yes no].freeze
  VALID_RELEASE_BLOCKING = %w[clear blocked waived not_applicable].freeze
  VALID_PROCESS_GAP_DISPOSITIONS = ["script", "schema", "checklist+replay", "park", "not applicable", "not_applicable"].freeze
  VALID_PRIORITY_SEVERITIES = %w[P0 P1 P2 P3 Must-Fix BLOCKING].freeze
  VALID_PRIORITY_DISPOSITIONS = %w[fixed waived false_positive not_applicable deferred_with_issue].freeze

  def run(argv)
    options, parser = parse_options(argv)
    if options.fetch(:help, false)
      puts parser
      return 0
    end

    path = argv.shift
    if path.nil?
      puts parser
      return 64
    end

    raise OptionParser::InvalidArgument, "unexpected arguments: #{argv.join(' ')}" unless argv.empty?

    text = path == "-" ? $stdin.read : File.read(path, encoding: "UTF-8")
    puts JSON.pretty_generate(
      replay(
        text,
        expected_head_sha: options[:expected_head_sha],
        require_priority_dispositions: options.fetch(:require_priority_dispositions, false)
      )
    )
    0
  rescue OptionParser::ParseError => e
    warn "Error: #{e.message}"
    64
  rescue Errno::ENOENT => e
    warn "Error: #{e.message}"
    1
  end

  def parse_options(argv)
    options = {}
    parser = OptionParser.new do |opts|
      opts.banner = "Usage: closeout-evidence-replay [--expected-head-sha SHA] [--require-priority-dispositions] <path|->"
      opts.separator ""
      opts.separator "Parse `qa-evidence v1` and `priority-finding-dispositions v1` markers from"
      opts.separator "a PR body, issue comment, handoff, or stdin and emit replay JSON."
      opts.separator ""
      opts.on("--expected-head-sha SHA", "Require QA and priority evidence for this full final-head SHA") do |sha|
        unless sha.match?(/\A[0-9a-f]{40}\z/i)
          raise OptionParser::InvalidArgument, "--expected-head-sha must be a full 40-character hex SHA"
        end

        options[:expected_head_sha] = sha.downcase
      end
      opts.on("--require-priority-dispositions", "Fail when priority evidence is missing or explicitly not_applicable") do
        options[:require_priority_dispositions] = true
      end
      opts.on("-h", "--help", "Show this help") { options[:help] = true }
    end
    parser.parse!(argv)
    [options, parser]
  end

  def replay(text, expected_head_sha: nil, require_priority_dispositions: false)
    qa = replay_qa_markers(marker_bodies(text, "qa-evidence v1"), expected_head_sha: expected_head_sha)
    priority = replay_priority_markers(
      marker_bodies(text, "priority-finding-dispositions v1"),
      expected_head_sha:,
      required: require_priority_dispositions
    )
    {
      "overall_verdict" => overall_verdict([qa, priority]),
      "qa_evidence" => qa,
      "priority_finding_dispositions" => priority
    }
  end

  def marker_bodies(text, name)
    text.scan(/<!--\s*#{Regexp.escape(name)}\s*(.*?)-->/m).map(&:first)
  end

  def replay_qa_markers(markers, expected_head_sha: nil)
    return unknown("qa-evidence marker missing") if markers.empty?

    markers = current_head_markers(markers, expected_head_sha) if expected_head_sha
    aggregate_marker_results(markers.map { |marker| replay_qa(marker, expected_head_sha: expected_head_sha) })
  end

  def replay_priority_markers(markers, expected_head_sha: nil, required: false)
    if markers.empty?
      return priority_unknown("priority-finding-dispositions marker missing") if required

      return priority_not_applicable("priority-finding-dispositions marker missing")
    end

    markers = current_head_markers(markers, expected_head_sha) if expected_head_sha
    aggregate_marker_results(markers.map { |marker| replay_priority(marker, expected_head_sha:, required:) })
  end

  def current_head_markers(markers, expected_head_sha)
    matching = markers.select do |marker|
      fields, duplicate_keys = parse_fields(marker)
      fields.fetch("head_sha", "").downcase == expected_head_sha || duplicate_keys.include?("head_sha")
    end
    matching.empty? ? markers : matching
  end

  def replay_qa(marker, expected_head_sha: nil)
    fields, duplicate_keys = parse_fields(marker)
    errors = duplicate_keys.map { |key| "duplicate scalar key: #{key}" }
    missing = missing_fields(
      fields,
      %w[required status tested_at scope automated_checks manual_checks findings release_blocking process_gap_disposition]
    )
    required = fields.fetch("required", "").to_s
    status = fields.fetch("status", "").to_s
    head_sha = fields.fetch("head_sha", "").to_s.downcase
    release_blocking = fields.fetch("release_blocking", "").to_s
    process_gap_disposition = fields.fetch("process_gap_disposition", "").to_s
    legacy_not_required_historical_marker = expected_head_sha.nil? && required == "no" && head_sha == "not_applicable"
    head_sha_valid = full_head_sha?(head_sha) || legacy_not_required_historical_marker
    final_head_mismatch = expected_head_sha && head_sha != expected_head_sha
    tested_at_head_mismatch = expected_head_sha &&
                              !tested_at_matches_head?(fields.fetch("tested_at", "").to_s, expected_head_sha)
    missing << "head_sha" if final_head_mismatch || !head_sha_valid
    missing << "tested_at.head_sha" if tested_at_head_mismatch
    missing << "required" unless required.empty? || VALID_QA_REQUIRED.include?(required)
    missing << "status" unless status.empty? || VALID_QA_STATUSES.include?(status)
    missing << "release_blocking" unless release_blocking.empty? || VALID_RELEASE_BLOCKING.include?(release_blocking)
    missing << "status" if required == "yes" && status == "not_applicable"
    if expected_head_sha && required == "no"
      missing << "status" unless status == "not_applicable"
      missing << "release_blocking" unless release_blocking == "not_applicable"
    end
    unless process_gap_disposition.empty? || VALID_PROCESS_GAP_DISPOSITIONS.include?(process_gap_disposition)
      missing << "process_gap_disposition"
    end

    verdict =
      if errors.any? || final_head_mismatch || tested_at_head_mismatch
        "UNKNOWN"
      elsif status == "blocked" || release_blocking == "blocked"
        "BLOCKED"
      elsif missing.any?
        "UNKNOWN"
      elsif status == "not_applicable" || required == "no"
        "NOT_APPLICABLE"
      elsif status == "waived" || release_blocking == "waived"
        "WAIVED"
      elsif status == "satisfied" && release_blocking == "clear"
        "SATISFIED"
      else
        "UNKNOWN"
      end

    result = {
      "verdict" => verdict,
      "fields" => fields,
      "missing" => missing,
      "errors" => errors
    }
    result["expected_head_sha"] = expected_head_sha if expected_head_sha
    result
  end

  def replay_priority(marker, expected_head_sha: nil, required: false)
    fields, duplicate_keys = parse_fields(marker)
    errors = duplicate_keys.map { |key| "duplicate scalar key: #{key}" }
    findings, finding_errors = parse_findings(marker)
    errors.concat(finding_errors)
    missing = []

    if errors.empty? && fields.fetch("status", "") == "not_applicable" && findings.empty?
      head_sha = fields.fetch("head_sha", "").downcase
      head_matches = !expected_head_sha || head_sha == expected_head_sha
      missing << "head_sha" unless full_head_sha?(head_sha) && head_matches
      missing << "finding" if required
      result = {
        "verdict" => missing.empty? ? "NOT_APPLICABLE" : "UNKNOWN",
        "fields" => fields,
        "findings" => [],
        "missing" => missing,
        "errors" => []
      }
      result["expected_head_sha"] = expected_head_sha if expected_head_sha
      return result
    end

    head_sha = fields.fetch("head_sha", "").downcase
    head_matches = !expected_head_sha || head_sha == expected_head_sha
    missing << "head_sha" unless full_head_sha?(head_sha) && head_matches
    missing << "finding" if findings.empty?
    findings.each_with_index do |finding, index|
      %w[url severity disposition evidence].each do |field|
        missing << "finding[#{index}].#{field}" if finding.fetch(field, "").empty?
      end
      disposition = finding.fetch("disposition", "")
      severity = finding.fetch("severity", "")
      unless severity.empty? || VALID_PRIORITY_SEVERITIES.include?(severity)
        missing << "finding[#{index}].severity"
      end
      unless disposition.empty? || VALID_PRIORITY_DISPOSITIONS.include?(disposition)
        missing << "finding[#{index}].disposition"
      end
      if disposition == "waived" && finding.fetch("waiver", "").empty?
        missing << "finding[#{index}].waiver"
      end
    end

    verdict =
      if errors.any? || missing.any?
        "UNKNOWN"
      elsif findings.any? { |finding| finding.fetch("disposition", "") == "waived" }
        "WAIVED"
      else
        "SATISFIED"
      end

    result = {
      "verdict" => verdict,
      "fields" => fields,
      "findings" => findings,
      "missing" => missing,
      "errors" => errors
    }
    result["expected_head_sha"] = expected_head_sha if expected_head_sha
    result
  end

  def aggregate_marker_results(results)
    return results.first.merge("marker_count" => 1) if results.length == 1

    aggregate = {
      "verdict" => aggregate_verdict(results),
      "fields" => {},
      "missing" => aggregate_missing(results),
      "errors" => aggregate_errors(results),
      "marker_count" => results.length,
      "markers" => results
    }
    if results.any? { |result| result.key?("findings") }
      aggregate["findings"] = results.flat_map { |result| result.fetch("findings", []) }
    end
    aggregate
  end

  def aggregate_missing(results)
    results.each_with_index.flat_map do |result, index|
      result.fetch("missing", []).map { |missing| "marker[#{index}].#{missing}" }
    end
  end

  def aggregate_errors(results)
    results.each_with_index.flat_map do |result, index|
      result.fetch("errors", []).map { |error| "marker[#{index}].#{error}" }
    end
  end

  def aggregate_verdict(results)
    verdicts = results.map { |result| result.fetch("verdict") }
    return "BLOCKED" if verdicts.include?("BLOCKED")
    return "UNKNOWN" if verdicts.include?("UNKNOWN")
    return "WAIVED" if verdicts.include?("WAIVED")
    return "NOT_APPLICABLE" if verdicts.all? { |verdict| verdict == "NOT_APPLICABLE" }

    "SATISFIED"
  end

  def parse_fields(marker)
    fields = {}
    duplicate_keys = []
    marker.each_line do |line|
      next if line.strip.start_with?("finding:")

      key, value = line.split(":", 2)
      next if value.nil?

      normalized_key = key.strip.downcase
      if fields.key?(normalized_key)
        duplicate_keys << normalized_key
      else
        fields[normalized_key] = value.strip
      end
    end
    [fields, duplicate_keys.uniq]
  end

  def tested_at_matches_head?(tested_at, expected_head_sha)
    full_shas = tested_at.scan(/(?<![0-9a-f])[0-9a-f]{40}(?![0-9a-f])/i).map(&:downcase)
    full_shas.last == expected_head_sha.downcase
  end

  def full_head_sha?(value)
    value.match?(/\A[0-9a-f]{40}\z/i)
  end

  def parse_findings(marker)
    findings = []
    errors = []
    marker.each_line do |line|
      next unless line.strip.start_with?("finding:")

      raw = line.split(":", 2).last.to_s
      finding = {}
      duplicate_keys = []
      raw.split("|").each do |part|
        key, value = part.split("=", 2)
        next if value.nil?

        normalized_key = key.strip.downcase
        if finding.key?(normalized_key)
          duplicate_keys << normalized_key
        else
          finding[normalized_key] = value.strip
        end
      end
      finding_index = findings.length
      findings << finding
      errors.concat(duplicate_keys.uniq.map { |key| "finding[#{finding_index}].duplicate key: #{key}" })
    end
    [findings, errors]
  end

  def missing_fields(fields, required)
    required.select { |field| fields.fetch(field, "").empty? }
  end

  def unknown(reason)
    {
      "verdict" => "UNKNOWN",
      "fields" => {},
      "missing" => [reason]
    }
  end

  def priority_not_applicable(reason)
    {
      "verdict" => "NOT_APPLICABLE",
      "fields" => { "status" => "not_applicable" },
      "findings" => [],
      "missing" => [],
      "errors" => [],
      "reason" => reason
    }
  end

  def priority_unknown(reason)
    {
      "verdict" => "UNKNOWN",
      "fields" => {},
      "findings" => [],
      "missing" => [reason],
      "errors" => []
    }
  end

  def overall_verdict(results)
    aggregate_verdict(results)
  end
end

exit(CloseoutEvidenceReplay.run(ARGV)) if $PROGRAM_NAME == __FILE__
