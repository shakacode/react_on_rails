{
  "compilerOptions": {
    "allowJs": true,
    "esModuleInterop": true,
    "jsx": "react-jsx",
    "lib": ["dom", "es2020"],
    "module": "es2020",
    "moduleResolution": "bundler",
    "noImplicitAny": true,
    "outDir": "node_package/lib",
    "strict": true,
    "incremental": true,
    "target": "es2020",
    "typeRoots": [
      "./node_modules/@types",
      "./node_modules/@shakacode-tools/react-on-rails-rsc/types",
      "./node_package/types"
    ]
  },
  "include": [
    "node_package/src/**/*",
    "node_modules/@shakacode-tools/react-on-rails-rsc/types",
    "node_package/types/**/*"
  ]
}
