# shellcheck shell=bash

# Shared helpers for scripts that need a reliable merge-base in shallow clones.
# Source this file from bash scripts; do not execute it directly.
#
# Tuning knobs:
# - GIT_DIFF_BASE_FETCH_DEPTH: initial fetch size, and first deepen size before doubling (default 50).
# - GIT_DIFF_BASE_MAX_ATTEMPTS: exponential deepen attempts before falling back to --unshallow
#   (default 8). With default depth, the deepen loop can fetch up to 12,750 commits total
#   before unshallowing.
# - GIT_DIFF_BASE_UNSHALLOW_TIMEOUT_SECONDS: maximum seconds for the --unshallow fallback when the
#   system timeout command is available (default 300; set 0 to disable the guard).

git_diff_base_remote_branch() {
  local ref="$1"

  case "$ref" in
    origin/*)
      printf '%s\n' "${ref#origin/}"
      ;;
    refs/remotes/origin/*)
      printf '%s\n' "${ref#refs/remotes/origin/}"
      ;;
    *)
      return 1
      ;;
  esac
}

git_diff_base_verify_ref() {
  local ref="$1"

  git rev-parse --verify "$ref^{commit}" >/dev/null 2>&1
}

git_diff_base_sha_ref() {
  local ref="$1"
  local length="${#ref}"

  case "$ref" in
    ""|*[!0-9a-fA-F]*)
      return 1
      ;;
  esac

  # Full GitHub event SHAs may be absent in shallow clones. Short hex strings
  # count only when they already resolve locally, avoiding hex branch-name hits.
  if [ "$length" -ne 40 ] && [ "$length" -ne 64 ] && ! git_diff_base_verify_ref "$ref"; then
    return 1
  fi

  if git rev-parse --verify "refs/heads/$ref" >/dev/null 2>&1; then
    return 1
  fi

  if git rev-parse --verify "refs/remotes/origin/$ref" >/dev/null 2>&1; then
    return 1
  fi

  return 0
}

git_diff_base_base_remote_branch() {
  local base_ref="$1"

  if git_diff_base_remote_branch "$base_ref"; then
    return 0
  fi

  # Pull request events can provide a raw base SHA while GITHUB_BASE_REF names
  # the branch to deepen. Push-event SHAs omit GITHUB_BASE_REF and fall through.
  if git_diff_base_sha_ref "$base_ref" && [ -n "${GITHUB_BASE_REF:-}" ]; then
    printf '%s\n' "$GITHUB_BASE_REF"
    return 0
  fi

  return 1
}

git_diff_base_fetch_refspec() {
  local branch="$1"
  printf '+refs/heads/%s:refs/remotes/origin/%s\n' "$branch" "$branch"
}

git_diff_base_unshallow_timeout_seconds() {
  local raw_timeout="${GIT_DIFF_BASE_UNSHALLOW_TIMEOUT_SECONDS:-300}"

  if [[ "$raw_timeout" =~ ^[[:space:]]*([0-9]+)[[:space:]]*$ ]]; then
    local timeout_seconds="${BASH_REMATCH[1]}"

    while [ "${#timeout_seconds}" -gt 1 ] && [ "${timeout_seconds#0}" != "$timeout_seconds" ]; do
      timeout_seconds="${timeout_seconds#0}"
    done

    printf '%s\n' "$timeout_seconds"
    return 0
  fi

  echo "Warning: invalid GIT_DIFF_BASE_UNSHALLOW_TIMEOUT_SECONDS '$raw_timeout';" \
    "running unshallow fetch without timeout." >&2
  printf '0\n'
}

git_diff_base_fetch_remote_branch() {
  local branch="$1"
  local mode="$2"
  local depth="${3:-${GIT_DIFF_BASE_FETCH_DEPTH:-50}}"
  local fetch_args=()
  local refspec

  refspec="$(git_diff_base_fetch_refspec "$branch")"

  case "$mode" in
    initial)
      fetch_args=(--depth="$depth" origin "$refspec")
      ;;
    deepen)
      fetch_args=(--deepen="$depth" origin "$refspec")
      ;;
    unshallow)
      # In full clones this becomes a plain branch fetch, used for missing refs
      # in CI checkouts that have history but not the base branch ref.
      if git_diff_base_is_shallow_repository; then
        fetch_args=(--unshallow origin "$refspec")
      else
        fetch_args=(origin "$refspec")
      fi
      ;;
    *)
      echo "Unknown fetch mode '$mode'" >&2
      return 1
      ;;
  esac

  # Keep fetch diagnostics visible while ensuring callers that use command
  # substitution capture only the merge-base SHA on stdout.
  if [ "$mode" = "unshallow" ]; then
    local unshallow_timeout

    unshallow_timeout="$(git_diff_base_unshallow_timeout_seconds)"

    if [ "$unshallow_timeout" -gt 0 ] 2>/dev/null; then
      if command -v timeout >/dev/null 2>&1; then
        timeout "$unshallow_timeout" git fetch "${fetch_args[@]}" >&2
        return $?
      fi

      echo "Warning: timeout command unavailable; running unshallow fetch without timeout." >&2
    fi
  fi

  git fetch "${fetch_args[@]}" >&2
}

git_diff_base_current_remote_branch() {
  local current_ref="$1"
  local upstream

  if git_diff_base_remote_branch "$current_ref"; then
    return 0
  fi

  if [ "$current_ref" = "HEAD" ]; then
    if [ -n "${GITHUB_HEAD_REF:-}" ]; then
      printf '%s\n' "$GITHUB_HEAD_REF"
      return 0
    fi

    if [ "${GITHUB_REF_TYPE:-}" = "branch" ] && [ -n "${GITHUB_REF_NAME:-}" ]; then
      printf '%s\n' "$GITHUB_REF_NAME"
      return 0
    fi

    if upstream="$(git rev-parse --abbrev-ref --symbolic-full-name '@{upstream}' 2>/dev/null)"; then
      git_diff_base_remote_branch "$upstream"
      return $?
    fi
  elif upstream="$(git rev-parse --abbrev-ref --symbolic-full-name "${current_ref}@{upstream}" 2>/dev/null)"; then
    git_diff_base_remote_branch "$upstream"
    return $?
  fi

  return 1
}

git_diff_base_merge_base() {
  local base_ref="$1"
  local current_ref="$2"

  if [ -n "${GIT_DIFF_BASE_DEBUG:-}" ]; then
    git merge-base "$base_ref" "$current_ref"
  else
    git merge-base "$base_ref" "$current_ref" 2>/dev/null
  fi
}

git_diff_base_is_shallow_repository() {
  [ "$(git rev-parse --is-shallow-repository 2>/dev/null || echo false)" = "true" ]
}

git_diff_base_resolve() {
  local base_ref="$1"
  local current_ref="$2"
  local initial_fetch_policy="${3:-strict}"
  local remote_branch=""
  local current_remote_branch=""
  local merge_base
  local is_shallow=false

  # The initial fetch policy only controls whether the first shallow base-branch
  # fetch failure aborts immediately. Missing refs, current-branch fetches, and
  # merge-base failures remain fatal under both policies.
  case "$initial_fetch_policy" in
    strict|required)
      initial_fetch_policy="strict"
      ;;
    lenient|optional)
      initial_fetch_policy="lenient"
      ;;
    *)
      echo "Error: unknown initial fetch policy '$initial_fetch_policy' (expected strict or lenient)" >&2
      return 1
      ;;
  esac

  # - strict: abort immediately when the initial fetch fails
  # - lenient: continue with cached local history after an initial fetch failure
  git_diff_base_is_shallow_repository && is_shallow=true

  if remote_branch="$(git_diff_base_base_remote_branch "$base_ref")"; then
    if [ "$is_shallow" = true ] && ! git_diff_base_fetch_remote_branch "$remote_branch" initial; then
      if [ "$initial_fetch_policy" = "strict" ]; then
        echo "Error: failed to fetch $base_ref from origin" >&2
        return 1
      fi
    fi
  else
    remote_branch=""
  fi

  if current_remote_branch="$(git_diff_base_current_remote_branch "$current_ref")"; then
    if [ "$current_remote_branch" != "$remote_branch" ] && [ "$is_shallow" = true ]; then
      # The current ref already exists locally; this fetch only expands shallow
      # history for better merge-base discovery, so keep it best-effort.
      if ! git_diff_base_fetch_remote_branch "$current_remote_branch" initial; then
        echo "Warning: failed to fetch origin/$current_remote_branch; continuing with local current ref." >&2
      fi
    fi
  else
    current_remote_branch=""
  fi

  # Initial depth-limited fetches can complete very small shallow repositories,
  # so refresh the flag before deciding whether more history can be fetched.
  if git_diff_base_is_shallow_repository; then
    is_shallow=true
  else
    is_shallow=false
  fi

  if ! git_diff_base_verify_ref "$base_ref" &&
    [ -n "$remote_branch" ] &&
    [ "$is_shallow" = false ]; then
    if ! git_diff_base_fetch_remote_branch "$remote_branch" unshallow; then
      if [ "$initial_fetch_policy" = "strict" ]; then
        echo "Error: failed to fetch $base_ref from origin" >&2
        return 1
      fi
    fi
  fi

  # Fail early when the base ref is still missing and there is no history left
  # to deepen: either this is already a full clone, or no remote branch is known.
  if ! git_diff_base_verify_ref "$base_ref" &&
    { [ "$is_shallow" = false ] || { [ -z "$remote_branch" ] && [ -z "$current_remote_branch" ]; }; }; then
    echo "Error: base ref '$base_ref' does not exist locally" >&2
    return 1
  fi

  if ! git_diff_base_verify_ref "$current_ref"; then
    echo "Error: current ref '$current_ref' does not exist locally" >&2
    return 1
  fi

  if git_diff_base_verify_ref "$base_ref" && merge_base="$(git_diff_base_merge_base "$base_ref" "$current_ref")"; then
    printf '%s\n' "$merge_base"
    return 0
  fi

  if ! git_diff_base_verify_ref "$base_ref" &&
    [ -z "$remote_branch" ] &&
    ! git_diff_base_sha_ref "$base_ref"; then
    echo "Error: base ref '$base_ref' does not exist locally and no remote branch is known to fetch it from" >&2
    return 1
  fi

  if [ -n "$remote_branch" ] || [ -n "$current_remote_branch" ]; then
    local attempt=1
    local deepen_attempts=0
    local deepen_depth="${GIT_DIFF_BASE_FETCH_DEPTH:-50}"
    local fetched=false
    local max_attempts="${GIT_DIFF_BASE_MAX_ATTEMPTS:-8}"

    # Re-check shallow state each time so tiny repositories can leave the loop
    # as soon as a deepen fetch completes their history.
    # When base_ref is a raw event SHA and no base branch is known, deepening
    # the current branch can still reveal a push-event before SHA ancestor.
    while [ "$attempt" -le "$max_attempts" ] && git_diff_base_is_shallow_repository; do
      fetched=false
      deepen_attempts=$((deepen_attempts + 1))

      # A successful deepen on either side can reveal the common ancestor, even
      # when the other branch fetch fails. Stop early only when every attempted
      # deepen fetch fails in the same iteration.
      if [ -n "$remote_branch" ] && git_diff_base_fetch_remote_branch "$remote_branch" deepen "$deepen_depth"; then
        fetched=true
      fi

      if [ -n "$current_remote_branch" ] && [ "$current_remote_branch" != "$remote_branch" ]; then
        if git_diff_base_fetch_remote_branch "$current_remote_branch" deepen "$deepen_depth"; then
          fetched=true
        fi
      fi

      if [ "$fetched" = false ]; then
        echo "Warning: all deepen fetches failed; stopping shallow history expansion. See git fetch output above." >&2
        break
      fi

      if git_diff_base_verify_ref "$base_ref" && merge_base="$(git_diff_base_merge_base "$base_ref" "$current_ref")"; then
        printf '%s\n' "$merge_base"
        return 0
      fi

      deepen_depth=$((deepen_depth * 2))
      attempt=$((attempt + 1))
    done

    if git_diff_base_is_shallow_repository; then
      is_shallow=true
    else
      is_shallow=false
    fi

    if [ "$is_shallow" = true ]; then
      echo "Warning: deepening did not find merge base after $deepen_attempts attempt(s);" \
        "falling back to --unshallow (this may be slow for large repositories)" >&2

      if [ -n "$remote_branch" ] && git_diff_base_fetch_remote_branch "$remote_branch" unshallow; then
        if git_diff_base_verify_ref "$base_ref" && merge_base="$(git_diff_base_merge_base "$base_ref" "$current_ref")"; then
          printf '%s\n' "$merge_base"
          return 0
        fi
      fi

      if [ -n "$current_remote_branch" ] && [ "$current_remote_branch" != "$remote_branch" ]; then
        git_diff_base_fetch_remote_branch "$current_remote_branch" unshallow || true
        if git_diff_base_verify_ref "$base_ref" && merge_base="$(git_diff_base_merge_base "$base_ref" "$current_ref")"; then
          printf '%s\n' "$merge_base"
          return 0
        fi
      fi
    fi
  fi

  if ! git_diff_base_verify_ref "$base_ref"; then
    echo "Error: base ref '$base_ref' still does not exist after fetching; unable to compute a merge base" >&2
  else
    echo "Error: unable to find a merge base between $base_ref and $current_ref" >&2
  fi

  if [ -n "$remote_branch" ]; then
    echo "Fetch more history for origin/$remote_branch or run git fetch --unshallow origin." >&2
  fi
  return 1
}
