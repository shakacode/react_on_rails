# shellcheck shell=bash

# Shared helpers for scripts that need a reliable merge-base in shallow clones.
# Source this file from bash scripts; do not execute it directly.
#
# Tuning knobs:
# - GIT_DIFF_BASE_FETCH_DEPTH: initial fetch size, and first deepen size before doubling.
# - GIT_DIFF_BASE_MAX_ATTEMPTS: exponential deepen attempts before falling back to --unshallow.

git_diff_base_remote_branch() {
  local ref="$1"

  case "$ref" in
    origin/*)
      printf '%s\n' "${ref#origin/}"
      ;;
    refs/remotes/origin/*)
      printf '%s\n' "${ref#refs/remotes/origin/}"
      ;;
    *)
      return 1
      ;;
  esac
}

git_diff_base_sha_ref() {
  local ref="$1"
  local length="${#ref}"

  case "$ref" in
    ""|*[!0-9a-fA-F]*)
      return 1
      ;;
  esac

  # Full GitHub event SHAs may be absent in shallow clones. Short hex strings
  # count only when they already resolve locally, avoiding hex branch-name hits.
  # git_diff_base_verify_ref is defined below and only called after sourcing.
  { [ "$length" -eq 40 ] || [ "$length" -eq 64 ] || git_diff_base_verify_ref "$ref"; } &&
    ! git rev-parse --verify "refs/heads/$ref" >/dev/null 2>&1 &&
    ! git rev-parse --verify "refs/remotes/origin/$ref" >/dev/null 2>&1
}

git_diff_base_base_remote_branch() {
  local base_ref="$1"

  if git_diff_base_remote_branch "$base_ref"; then
    return 0
  fi

  # Pull request events can provide a raw base SHA while GITHUB_BASE_REF names
  # the branch to deepen. Push-event SHAs omit GITHUB_BASE_REF and fall through.
  if git_diff_base_sha_ref "$base_ref" && [ -n "${GITHUB_BASE_REF:-}" ]; then
    printf '%s\n' "$GITHUB_BASE_REF"
    return 0
  fi

  return 1
}

git_diff_base_fetch_refspec() {
  local branch="$1"
  printf '+refs/heads/%s:refs/remotes/origin/%s\n' "$branch" "$branch"
}

git_diff_base_fetch_remote_branch() {
  local branch="$1"
  local mode="$2"
  local depth="${3:-${GIT_DIFF_BASE_FETCH_DEPTH:-50}}"
  local fetch_args=()
  local refspec

  refspec="$(git_diff_base_fetch_refspec "$branch")"

  case "$mode" in
    initial)
      fetch_args=(--depth="$depth" origin "$refspec")
      ;;
    deepen)
      fetch_args=(--deepen="$depth" origin "$refspec")
      ;;
    unshallow)
      # In full clones this becomes a plain branch fetch, used for missing refs
      # in CI checkouts that have history but not the base branch ref.
      if git_diff_base_is_shallow_repository; then
        fetch_args=(--unshallow origin "$refspec")
      else
        fetch_args=(origin "$refspec")
      fi
      ;;
    *)
      echo "Unknown fetch mode '$mode'" >&2
      return 1
      ;;
  esac

  # Keep fetch diagnostics visible while ensuring callers that use command
  # substitution capture only the merge-base SHA on stdout.
  git fetch "${fetch_args[@]}" >&2
}

git_diff_base_current_remote_branch() {
  local current_ref="$1"
  local upstream

  if git_diff_base_remote_branch "$current_ref"; then
    return 0
  fi

  if [ "$current_ref" = "HEAD" ]; then
    if [ -n "${GITHUB_HEAD_REF:-}" ]; then
      printf '%s\n' "$GITHUB_HEAD_REF"
      return 0
    fi

    if [ "${GITHUB_REF_TYPE:-}" = "branch" ] && [ -n "${GITHUB_REF_NAME:-}" ]; then
      printf '%s\n' "$GITHUB_REF_NAME"
      return 0
    fi

    if upstream="$(git rev-parse --abbrev-ref --symbolic-full-name '@{upstream}' 2>/dev/null)"; then
      git_diff_base_remote_branch "$upstream"
      return $?
    fi
  elif upstream="$(git rev-parse --abbrev-ref --symbolic-full-name "${current_ref}@{upstream}" 2>/dev/null)"; then
    git_diff_base_remote_branch "$upstream"
    return $?
  fi

  return 1
}

git_diff_base_verify_ref() {
  local ref="$1"

  git rev-parse --verify "$ref^{commit}" >/dev/null 2>&1
}

git_diff_base_merge_base() {
  local base_ref="$1"
  local current_ref="$2"

  if [ -n "${GIT_DIFF_BASE_DEBUG:-}" ]; then
    git merge-base "$base_ref" "$current_ref"
  else
    git merge-base "$base_ref" "$current_ref" 2>/dev/null
  fi
}

git_diff_base_is_shallow_repository() {
  [ "$(git rev-parse --is-shallow-repository 2>/dev/null || echo false)" = "true" ]
}

git_diff_base_resolve() {
  local base_ref="$1"
  local current_ref="$2"
  local fetch_policy="${3:-required}"
  local remote_branch=""
  local current_remote_branch=""
  local merge_base
  local is_shallow=false

  case "$fetch_policy" in
    required|optional)
      ;;
    *)
      echo "Error: unknown fetch_policy '$fetch_policy' (expected required or optional initial fetch handling)" >&2
      return 1
      ;;
  esac

  # fetch_policy only controls the first shallow base-branch fetch failure:
  # - required: abort immediately when the initial fetch fails
  # - optional: continue with cached local history after an initial fetch failure
  # Missing refs, current-branch fetches, and merge-base failures remain fatal.
  git_diff_base_is_shallow_repository && is_shallow=true

  if remote_branch="$(git_diff_base_base_remote_branch "$base_ref")"; then
    if [ "$is_shallow" = true ] && ! git_diff_base_fetch_remote_branch "$remote_branch" initial; then
      if [ "$fetch_policy" = "required" ]; then
        echo "Error: failed to fetch $base_ref from origin" >&2
        return 1
      fi
    fi
  else
    remote_branch=""
  fi

  if current_remote_branch="$(git_diff_base_current_remote_branch "$current_ref")"; then
    if [ "$current_remote_branch" != "$remote_branch" ] && [ "$is_shallow" = true ]; then
      git_diff_base_fetch_remote_branch "$current_remote_branch" initial || true
    fi
  else
    current_remote_branch=""
  fi

  if ! git_diff_base_verify_ref "$base_ref" &&
    [ -n "$remote_branch" ] &&
    [ "$is_shallow" = false ]; then
    if ! git_diff_base_fetch_remote_branch "$remote_branch" unshallow; then
      if [ "$fetch_policy" = "required" ]; then
        echo "Error: failed to fetch $base_ref from origin" >&2
        return 1
      fi
    fi
  fi

  if ! git_diff_base_verify_ref "$base_ref" &&
    { [ "$is_shallow" = false ] || { [ -z "$remote_branch" ] && [ -z "$current_remote_branch" ]; }; }; then
    echo "Error: base ref '$base_ref' does not exist locally" >&2
    return 1
  fi

  if ! git_diff_base_verify_ref "$current_ref"; then
    echo "Error: current ref '$current_ref' does not exist locally" >&2
    return 1
  fi

  if git_diff_base_verify_ref "$base_ref" && merge_base="$(git_diff_base_merge_base "$base_ref" "$current_ref")"; then
    printf '%s\n' "$merge_base"
    return 0
  fi

  if [ -n "$remote_branch" ] || [ -n "$current_remote_branch" ]; then
    local attempt=1
    local deepen_depth="${GIT_DIFF_BASE_FETCH_DEPTH:-50}"
    local fetched=false
    local max_attempts="${GIT_DIFF_BASE_MAX_ATTEMPTS:-8}"

    # Keep the original shallow state for this expansion pass. Each successful
    # deepen/unshallow attempt is followed by a merge-base check before retrying.
    while [ "$attempt" -le "$max_attempts" ] && [ "$is_shallow" = true ]; do
      fetched=false

      if [ -n "$remote_branch" ] && git_diff_base_fetch_remote_branch "$remote_branch" deepen "$deepen_depth"; then
        fetched=true
      fi

      if [ -n "$current_remote_branch" ] && [ "$current_remote_branch" != "$remote_branch" ]; then
        if git_diff_base_fetch_remote_branch "$current_remote_branch" deepen "$deepen_depth"; then
          fetched=true
        fi
      fi

      if [ "$fetched" = false ]; then
        echo "Warning: all deepen fetches failed; stopping shallow history expansion. See git fetch output above." >&2
        break
      fi

      if git_diff_base_verify_ref "$base_ref" && merge_base="$(git_diff_base_merge_base "$base_ref" "$current_ref")"; then
        printf '%s\n' "$merge_base"
        return 0
      fi

      deepen_depth=$((deepen_depth * 2))
      attempt=$((attempt + 1))
    done

    if [ "$is_shallow" = true ]; then
      if [ -n "$remote_branch" ] && git_diff_base_fetch_remote_branch "$remote_branch" unshallow; then
        if git_diff_base_verify_ref "$base_ref" && merge_base="$(git_diff_base_merge_base "$base_ref" "$current_ref")"; then
          printf '%s\n' "$merge_base"
          return 0
        fi
      fi

      if [ -n "$current_remote_branch" ] && [ "$current_remote_branch" != "$remote_branch" ]; then
        git_diff_base_fetch_remote_branch "$current_remote_branch" unshallow || true
        if git_diff_base_verify_ref "$base_ref" && merge_base="$(git_diff_base_merge_base "$base_ref" "$current_ref")"; then
          printf '%s\n' "$merge_base"
          return 0
        fi
      fi
    fi
  fi

  echo "Error: unable to find a merge base between $base_ref and $current_ref" >&2
  if [ -n "$remote_branch" ]; then
    echo "Fetch more history for origin/$remote_branch or run git fetch --unshallow origin." >&2
  fi
  return 1
}
