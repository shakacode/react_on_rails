{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "sandbox_network_access", "limits", "npm", "rubygems", "overall"],
  "properties": {
    "schema_version": { "const": "1.0" },
    "sandbox_network_access": { "type": "boolean" },
    "limits": { "$ref": "#/$defs/eventLimits" },
    "npm": { "$ref": "#/$defs/probe" },
    "rubygems": { "$ref": "#/$defs/probe" },
    "overall": { "enum": ["pass", "fail"] }
  },
  "$defs": {
    "eventLimits": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "max_bytes",
        "max_events",
        "observed_bytes",
        "observed_events",
        "exceeded",
        "reason"
      ],
      "properties": {
        "max_bytes": { "type": "integer", "minimum": 1 },
        "max_events": { "type": "integer", "minimum": 1 },
        "observed_bytes": { "type": "integer", "minimum": 0 },
        "observed_events": { "type": ["integer", "null"], "minimum": 0 },
        "exceeded": { "type": "boolean" },
        "reason": { "enum": [null, "events_bytes", "events_count"] }
      }
    },
    "probe": {
      "type": "object",
      "additionalProperties": false,
      "required": ["attempts", "status"],
      "properties": {
        "attempts": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["command_id", "exit_code"],
            "properties": {
              "command_id": { "type": "string" },
              "exit_code": { "type": ["integer", "null"] }
            }
          }
        },
        "status": { "enum": ["pass", "fail"] }
      }
    }
  }
}
