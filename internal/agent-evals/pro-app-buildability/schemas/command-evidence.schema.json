{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "limits", "commands"],
  "properties": {
    "schema_version": { "const": "1.0" },
    "limits": { "$ref": "#/$defs/eventLimits" },
    "commands": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "command", "exit_code", "status", "output", "output_truncated"],
        "properties": {
          "id": { "type": "string", "pattern": "^command-[0-9]+$" },
          "command": { "type": "string" },
          "exit_code": { "type": ["integer", "null"] },
          "status": { "type": "string" },
          "output": { "type": "string" },
          "output_truncated": { "type": "boolean" }
        }
      }
    }
  },
  "$defs": {
    "eventLimits": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "max_bytes",
        "max_events",
        "observed_bytes",
        "observed_events",
        "exceeded",
        "reason"
      ],
      "properties": {
        "max_bytes": { "type": "integer", "minimum": 1 },
        "max_events": { "type": "integer", "minimum": 1 },
        "observed_bytes": { "type": "integer", "minimum": 0 },
        "observed_events": { "type": ["integer", "null"], "minimum": 0 },
        "exceeded": { "type": "boolean" },
        "reason": { "enum": [null, "events_bytes", "events_count"] }
      }
    }
  }
}
