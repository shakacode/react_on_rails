#!/usr/bin/env bash
set -euo pipefail

root="$(git rev-parse --show-toplevel)"
eval_dir="$root/internal/agent-evals/pro-app-buildability"
tmp="$(mktemp -d "${TMPDIR:-/tmp}/ror-eval-tests.XXXXXX")"
trap 'rm -rf "$tmp"' EXIT INT TERM

node "$eval_dir/bin/validate-json.mjs" --schemas-only

printf '%s\n' 'authorization: super-sensitive-value' 'authorization: Bearer multi-word-secret' \
  '/tmp/private/place' '/private/tmp/agent-cache' \
  '-----BEGIN PRIVATE KEY-----' 'line-one' 'line-two' '-----END PRIVATE KEY-----' >"$tmp/unsafe"
EVAL_PRIVATE_DIR="$tmp" perl "$eval_dir/bin/sanitize-events.pl" "$tmp/unsafe" >"$tmp/safe"
rg -q '\[REDACTED\]' "$tmp/safe"
rg -q '<LOCAL_PATH>' "$tmp/safe"
if rg -q 'super-sensitive-value|multi-word-secret|/tmp/private/place|/private/tmp/agent-cache|line-one|line-two' \
  "$tmp/safe"; then
  echo "sanitizer negative test failed" >&2
  exit 1
fi
test "$(rg -o '\[REDACTED\]' "$tmp/safe" | wc -l | tr -d ' ')" -ge 2

rg -q '^umask 077$' "$eval_dir/bin/run-eval"
rg -q '^trap cleanup EXIT$' "$eval_dir/bin/run-eval"
rg -q "^trap 'exit 130' INT TERM$" "$eval_dir/bin/run-eval"
rg -q 'minimal_env=\(env -i' "$eval_dir/bin/run-eval"
rg -q "shell_environment_policy.inherit='?\\\"none\\\"'?" "$eval_dir/bin/run-eval"
rg -q 'sandbox_workspace_write.network_access=true' "$eval_dir/bin/run-eval"
rg -q 'cli_auth_credentials_store=.?keyring' "$eval_dir/bin/run-eval"
rg -q 'node npm perl pnpm' "$eval_dir/bin/run-eval"
if rg -q 'cp .*auth|install .*auth' "$eval_dir/bin/run-eval"; then
  echo "runner must not copy authentication into the sandbox filesystem" >&2
  exit 1
fi

printf '%013000d' 0 >"$tmp/long-stderr"
"$eval_dir/bin/build-runner-diagnostics" "$tmp/long-stderr" "$tmp/long-diagnostics.json"
test "$(jq -r .stderr_line_count "$tmp/long-diagnostics.json")" = 0
test "$(jq -r .excerpt_truncated "$tmp/long-diagnostics.json")" = true
test "$(jq -r '.excerpt | length' "$tmp/long-diagnostics.json")" = 12000
"$eval_dir/bin/probe-allows-scaffold" 0 pass
if "$eval_dir/bin/probe-allows-scaffold" 1 pass; then
  echo "nonzero probe exit incorrectly allows scaffold" >&2
  exit 1
fi

mkdir "$tmp/user-bin"
printf '%s\n' '#!/bin/sh' 'exit 0' >"$tmp/user-bin/user-tool"
printf '%s\n' '#!/bin/sh' 'exit 0' >"$tmp/user-bin/node"
chmod +x "$tmp/user-bin/user-tool"
chmod +x "$tmp/user-bin/node"
test_path="$tmp/user-bin:/opt/homebrew/bin:/usr/bin:/bin"
resolved_path="$(SAFE_PATH_SOURCE="$test_path" BASH_ENV=/dev/null PATH="$test_path" \
  "$eval_dir/bin/build-safe-path" user-tool node sh)"
env -i PATH="$resolved_path" /bin/sh -c 'command -v user-tool >/dev/null'
test "$(realpath "$(env -i PATH="$resolved_path" /bin/sh -c 'command -v node')")" = \
  "$(realpath "$tmp/user-bin/node")"

mise_node="$(SAFE_PATH_SOURCE="$PATH" BASH_ENV=/dev/null \
  "$eval_dir/bin/build-safe-path" --resolve node)"
if [[ "$(basename "$(realpath "$(command -v node)")")" == mise ]]; then
  test "$(realpath "$mise_node")" != "$(realpath "$(command -v node)")"
  test "$(env -i PATH="$(dirname "$mise_node"):/usr/bin:/bin" node --version)" = "$(node --version)"
  mise_ruby="$(SAFE_PATH_SOURCE="$PATH" BASH_ENV=/dev/null \
    "$eval_dir/bin/build-safe-path" --resolve ruby)"
  mise_path="$(SAFE_PATH_SOURCE="$PATH" BASH_ENV=/dev/null \
    "$eval_dir/bin/build-safe-path" node ruby sh)"
  test "$(realpath "$(env -i PATH="$mise_path" /bin/sh -c 'command -v node')")" = "$(realpath "$mise_node")"
  test "$(realpath "$(env -i PATH="$mise_path" /bin/sh -c 'command -v ruby')")" = "$(realpath "$mise_ruby")"
fi

mkdir "$tmp/world-writable-bin"
printf '%s\n' '#!/bin/sh' 'exit 0' >"$tmp/world-writable-bin/unsafe-tool"
chmod +x "$tmp/world-writable-bin/unsafe-tool"
chmod 777 "$tmp/world-writable-bin"
unsafe_path="$tmp/world-writable-bin:/usr/bin:/bin"
if SAFE_PATH_SOURCE="$unsafe_path" BASH_ENV=/dev/null PATH="$unsafe_path" \
  "$eval_dir/bin/build-safe-path" unsafe-tool \
  2>"$tmp/unsafe-path-error"; then
  echo "world-writable command directory was retained" >&2
  exit 1
fi
rg -q 'world-writable' "$tmp/unsafe-path-error"

mkdir "$tmp/real-workspace"
ln -s "$tmp/real-workspace" "$tmp/workspace-link"
if "$eval_dir/bin/run-eval" --agent codex --model test-model --timeout 10 \
  --workspace "$tmp/workspace-link" --output "$tmp/output" 2>"$tmp/symlink-error"; then
  echo "symlink workspace negative test failed" >&2
  exit 1
fi
rg -q 'symlink inputs are forbidden' "$tmp/symlink-error"

printf '%s\n' \
  '{"schema_version":"1.0","sandbox_network_access":true,"npm":{"attempts":[{"command_id":"command-1","exit_code":1}],"status":"pass"},"rubygems":{"attempts":[],"status":"fail"},"overall":"pass"}' \
  >"$tmp/contradictory-probe.json"
printf '%s\n' '{"schema_version":"1.0","commands":[{"id":"command-1","command":"npm view","exit_code":1,"status":"failed","output":"","output_truncated":false}]}' \
  >"$tmp/probe-commands.json"
if node "$eval_dir/bin/validate-network-probe.mjs" \
  "$tmp/contradictory-probe.json" "$tmp/probe-commands.json" 2>"$tmp/probe-error"; then
  echo "contradictory network probe negative test failed" >&2
  exit 1
fi
rg -q 'contradicts' "$tmp/probe-error"

printf '%s\n' \
  '{"schema_version":"1.0","sandbox_network_access":true,"npm":{"attempts":[{"command_id":"command-1","exit_code":0}],"status":"pass"},"rubygems":{"attempts":[],"status":"fail"},"overall":"fail"}' \
  >"$tmp/wrong-command-probe.json"
printf '%s\n' '{"schema_version":"1.0","commands":[{"id":"command-1","command":"npm view unrelated-package version --json","exit_code":0,"status":"completed","output":"1.0.0","output_truncated":false}]}' \
  >"$tmp/wrong-command-evidence.json"
if node "$eval_dir/bin/validate-network-probe.mjs" \
  "$tmp/wrong-command-probe.json" "$tmp/wrong-command-evidence.json" 2>"$tmp/wrong-command-error"; then
  echo "wrong probe command text was accepted" >&2
  exit 1
fi
rg -q 'exact required probe' "$tmp/wrong-command-error"

printf '%s\n' \
  '{"type":"item.completed","item":{"type":"command_execution","command":"npm view create-react-on-rails-app version --json","exit_code":1}}' \
  '{"type":"item.completed","item":{"type":"command_execution","command":"npm view create-react-on-rails-app version --json","exit_code":0}}' \
  '{"type":"item.completed","item":{"type":"command_execution","command":"gem search --remote --exact '\''^rails$'\''","exit_code":0}}' \
  >"$tmp/retried-probe-events.jsonl"
node "$eval_dir/bin/derive-network-probe.mjs" "$tmp/retried-probe-events.jsonl" "$tmp/retried-probe.json"
test "$(jq -r '.npm.attempts | length' "$tmp/retried-probe.json")" = 2
test "$(jq -r '.npm.status' "$tmp/retried-probe.json")" = fail
test "$(jq -r '.overall' "$tmp/retried-probe.json")" = fail

mkdir "$tmp/evidence-workspace" "$tmp/evidence-output"
printf '%s\n' \
  '{"type":"item.completed","item":{"type":"command_execution","command":"bin/rails assets:precompile --help","exit_code":0,"status":"completed","aggregated_output":"Usage: assets:precompile [options] - assets compiled successfully"}}' \
  '{"type":"item.completed","item":{"type":"command_execution","command":"npx create-react-on-rails-app --help","exit_code":0,"status":"completed","aggregated_output":"Usage: create-react-on-rails-app APP"}}' \
  >"$tmp/generic-build-events.jsonl"
mkdir "$tmp/evidence-workspace/eval_app"
printf '%s\n' "gem 'react_on_rails_pro'" >"$tmp/evidence-workspace/eval_app/Gemfile"
printf '%s\n' '{"dependencies":{"react-on-rails-pro":"1.0.0"}}' >"$tmp/evidence-workspace/eval_app/package.json"
printf '%s\n' '{"status":"completed","summary":"fixture","commands":[],"checks":[],"friction":[],"human_interventions":0,"blockers":[]}' \
  >"$tmp/fixture-report.json"
node "$eval_dir/bin/derive-evidence.mjs" "$tmp/generic-build-events.jsonl" \
  "$tmp/evidence-workspace" "$tmp/evidence-output" "$tmp/fixture-report.json"
test "$(jq -r '.items[] | select(.id == "build.production") | .status' "$tmp/evidence-output/rubric-results.json")" = unknown
test "$(jq -r '.items[] | select(.id == "install.pro") | .status' "$tmp/evidence-output/rubric-results.json")" = unknown

mkdir -p "$tmp/correlation-workspace/eval_app/app/components" \
  "$tmp/correlation-workspace/eval_app/app/models" \
  "$tmp/correlation-workspace/eval_app/app/controllers" \
  "$tmp/correlation-workspace/eval_app/config" \
  "$tmp/correlation-workspace/eval_app/spec/pages" \
  "$tmp/correlation-workspace/eval_app/spec/requests"
printf '%s\n' 'rsc_route server_component' >"$tmp/correlation-workspace/eval_app/config/routes.rb"
printf '%s\n' 'export const Page = () => null' >"$tmp/correlation-workspace/eval_app/app/components/page.server.tsx"
printf '%s\n' 'it { expect(page).to be_present }' >"$tmp/correlation-workspace/eval_app/spec/pages/rsc_page_spec.rb"
printf '%s\n' 'validates :name, presence: true' >"$tmp/correlation-workspace/eval_app/app/models/form.rb"
printf '%s\n' 'render errors, status: :unprocessable_entity' \
  >"$tmp/correlation-workspace/eval_app/app/controllers/forms_controller.rb"
printf '%s\n' 'it tests invalid and valid form outcomes' \
  >"$tmp/correlation-workspace/eval_app/spec/requests/form_spec.rb"
printf '%s\n' \
  '{"type":"item.completed","item":{"type":"command_execution","command":"bundle exec rspec spec/unrelated_spec.rb","exit_code":0,"status":"completed","aggregated_output":"1 example, 0 failures"}}' \
  >"$tmp/unrelated-test-events.jsonl"
mkdir "$tmp/correlation-output"
node "$eval_dir/bin/derive-evidence.mjs" "$tmp/unrelated-test-events.jsonl" \
  "$tmp/correlation-workspace" "$tmp/correlation-output" "$tmp/fixture-report.json"
for row in rsc.route form.validation tests.page tests.form; do
  test "$(jq -r --arg row "$row" '.items[] | select(.id == $row) | .status' \
    "$tmp/correlation-output/rubric-results.json")" = unknown
done

echo "focused harness tests passed"
