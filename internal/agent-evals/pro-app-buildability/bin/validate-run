#!/usr/bin/env bash
set -euo pipefail

run_dir="${1:-}"
[[ -d "$run_dir" ]] || { echo "usage: $0 RUN_DIRECTORY" >&2; exit 64; }
root="$(git rev-parse --show-toplevel)"
eval_dir="$root/internal/agent-evals/pro-app-buildability"

for command in jq node rg shasum; do
  command -v "$command" >/dev/null || { echo "missing required command: $command" >&2; exit 69; }
done
[[ -d "$eval_dir/node_modules/ajv" && -d "$eval_dir/node_modules/ajv-formats" && -d "$eval_dir/node_modules/prettier" ]] || {
  echo "install pinned validator dependencies: pnpm --dir $eval_dir install --frozen-lockfile --ignore-workspace" >&2
  exit 69
}

for file in run.json agent-report.json command-evidence.json artifact-evidence.json rubric-results.json \
  sandbox-network-probe.json invocation.json runner-diagnostics.json prompt.md scenario.md rubric.md workspace-status.txt SHA256SUMS; do
  [[ -f "$run_dir/$file" ]] || { echo "missing artifact: $file" >&2; exit 1; }
done
for forbidden in events.unredacted.jsonl events.redacted.jsonl runner.stderr auth.json; do
  [[ ! -e "$run_dir/$forbidden" ]] || { echo "forbidden broad or sensitive artifact: $forbidden" >&2; exit 1; }
done

node "$eval_dir/bin/validate-json.mjs" "$run_dir"
node "$eval_dir/bin/validate-network-probe.mjs" \
  "$run_dir/sandbox-network-probe.json" "$run_dir/command-evidence.json"

recorded_revision="$(jq -r .repository.revision "$run_dir/run.json")"
while IFS=$'\t' read -r relative expected; do
  current=""
  [[ -f "$eval_dir/$relative" ]] && current="$(shasum -a 256 "$eval_dir/$relative" | awk '{print $1}')"
  if [[ "$expected" == "$current" ]]; then continue; fi
  recorded="$(git -C "$root" show "$recorded_revision:internal/agent-evals/pro-app-buildability/$relative" 2>/dev/null | \
    shasum -a 256 | awk '{print $1}')"
  [[ "$expected" == "$recorded" ]] || { echo "harness input hash mismatch: $relative" >&2; exit 1; }
done < <(jq -r '.definition.inputs[] | [.path,.sha256] | @tsv' "$run_dir/run.json")

actual_files="$(cd "$run_dir" && find . -maxdepth 1 -type f ! -name SHA256SUMS -print | LC_ALL=C sort | sed 's#^./##')"
listed_files="$(awk '{print $2}' "$run_dir/SHA256SUMS" | LC_ALL=C sort)"
[[ "$actual_files" == "$listed_files" ]] || { echo "SHA256SUMS coverage mismatch" >&2; exit 1; }
(cd "$run_dir" && shasum -a 256 -c SHA256SUMS)

if rg -n '/Users/|/tmp/|/private/tmp|/var/folders/' "$run_dir"; then
  echo "local absolute path found" >&2
  exit 1
fi
if rg -n --pcre2 --ignore-case \
  "(bearer[[:space:]]+[a-z0-9._-]{12,}|-----BEGIN [A-Z ]*PRIVATE KEY-----|(?:api[_-]?key|token|secret|password|license[_-]?key)[\"'=: ]+[A-Za-z0-9_./+=-]{12,})" \
  "$run_dir"; then
  echo "possible unredacted credential found" >&2
  exit 1
fi

run_classification="$(jq -r .result.classification "$run_dir/run.json")"
rubric_classification="$(jq -r .overall "$run_dir/rubric-results.json")"
[[ "$run_classification" == "$rubric_classification" ]] || { echo "run/rubric classification mismatch" >&2; exit 1; }
[[ "$(jq -r .result.tutorial_claims_supported "$run_dir/run.json")" == false ]] || {
  echo "a single run cannot enable tutorial claims" >&2
  exit 1
}
probe_result="$(jq -r .overall "$run_dir/sandbox-network-probe.json")"
scaffold_invoked="$(jq -r .agent.scaffold_invoked "$run_dir/run.json")"
if [[ "$probe_result" == pass ]]; then
  [[ "$scaffold_invoked" == true ]] || { echo "passing network probe must start scaffold attempt" >&2; exit 1; }
else
  [[ "$scaffold_invoked" == false ]] || { echo "failed network probe must block scaffold attempt" >&2; exit 1; }
  [[ "$run_classification" == incomplete ]] || { echo "failed network probe must be incomplete" >&2; exit 1; }
fi

echo "run artifacts valid: $run_dir"
