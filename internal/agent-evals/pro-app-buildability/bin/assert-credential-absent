#!/usr/bin/env bash
# Fail closed unless the operator-provided model credential is entirely absent
# from the committed run output. This enforces the `auth_material_persisted:false`
# invariant at runtime: the broker seeds the credential ONLY into the mode-0700
# private directory, never into the evidence surface. The check never prints or
# passes credential bytes as arguments; it compares SHA-256 digests only.
set -euo pipefail

output_dir="${1:-}"
credential_file="${2:-}"
[[ -d "$output_dir" && -f "$credential_file" ]] || {
  echo "usage: assert-credential-absent OUTPUT_DIRECTORY CREDENTIAL_FILE" >&2
  exit 64
}

credential_real="$(realpath "$credential_file")"
output_real="$(realpath "$output_dir")"
case "$credential_real/" in
  "$output_real/"*)
    echo "operator credential path resolves inside the run output: $output_dir" >&2
    exit 1
    ;;
esac

credential_sha="$(shasum -a 256 "$credential_file" | awk '{print $1}')"
while IFS= read -r artifact; do
  [[ "$(shasum -a 256 "$artifact" | awk '{print $1}')" != "$credential_sha" ]] || {
    echo "operator credential copied verbatim into run output: $artifact" >&2
    exit 1
  }
done < <(find "$output_real" -type f)

exit 0
