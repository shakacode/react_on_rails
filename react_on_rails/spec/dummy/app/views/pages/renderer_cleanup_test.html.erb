<h1>Renderer cleanup test</h1>

<p>
  Mounts a renderer function that returns a teardown closure. Navigating away
  via Turbo invokes the teardown, which unmounts the React root and fires the
  tree's <code>useEffect</code> cleanup, incrementing
  <code>window.__rendererCleanupCount__</code>.
</p>

<%= react_component(
  "RendererCleanupTest",
  props: {},
  prerender: false,
  id: "RendererCleanupTest-1",
  auto_load_bundle: false,
) %>

<p>
  <%= link_to "Navigate away (Turbo)", manual_render_test_path, id: "renderer-cleanup-leave-link" %>
</p>
