#!/usr/bin/env bash
# Local CI Runner
# Runs appropriate CI checks based on changes in current branch
# Usage: bin/ci-local [--all] [--fast] [--changed]

set -euo pipefail

usage() {
  cat <<'USAGE'
Usage: bin/ci-local [--all] [--fast] [--changed]

Runs optimized local CI for the current branch by default. The comparison base is
auto-detected from the current GitHub PR when available, then falls back to main.

Options:
  --all       Run the broad local CI suite where practical.
  --fast      Skip the slowest local suites after change detection.
  --changed   Explicitly request the default optimized changed-files mode.
  -h, --help  Show this help.
USAGE
}

# Parse arguments
RUN_ALL=false
FAST_MODE=false

while [[ $# -gt 0 ]]; do
  case $1 in
    --all)
      RUN_ALL=true
      shift
      ;;
    --fast)
      FAST_MODE=true
      shift
      ;;
    --changed)
      RUN_ALL=false
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      echo "Unknown argument: $1" >&2
      usage >&2
      exit 2
      ;;
  esac
done

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

echo -e "${BLUE}=== React on Rails Local CI ===${NC}"
echo ""

ROOT_DIR="$(git rev-parse --show-toplevel)"
ROOT_GEMFILE="$ROOT_DIR/Gemfile"
OSS_GEMFILE="$ROOT_DIR/react_on_rails/Gemfile"
PRO_GEMFILE="$ROOT_DIR/react_on_rails_pro/Gemfile"
PRO_DUMMY_GEMFILE="$ROOT_DIR/react_on_rails_pro/spec/dummy/Gemfile"
PRO_EXECJS_DUMMY_GEMFILE="$ROOT_DIR/react_on_rails_pro/spec/execjs-compatible-dummy/Gemfile"
cd "$ROOT_DIR"

detect_base_ref() {
  local base_branch=""

  if command -v gh >/dev/null 2>&1; then
    base_branch="$(gh pr view --json baseRefName --jq .baseRefName 2>/dev/null || true)"
  fi

  if [ -n "$base_branch" ]; then
    for candidate in "origin/$base_branch" "$base_branch"; do
      if git rev-parse --verify "${candidate}^{commit}" >/dev/null 2>&1; then
        printf '%s\n' "$candidate"
        return 0
      fi
    done
  fi

  for candidate in origin/main main; do
    if git rev-parse --verify "${candidate}^{commit}" >/dev/null 2>&1; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done

  return 1
}

if ! BASE_REF="$(detect_base_ref)"; then
  echo -e "${RED}Could not auto-detect a base ref. Fetch origin/main or check out a PR branch.${NC}" >&2
  exit 1
fi

# Keep this helper in sync with bin/ci-rerun-failures and bin/setup.
bundle_command() {
  local gemfile="$1"
  shift

  env \
    -u BUNDLE_APP_CONFIG \
    -u BUNDLE_BIN_PATH \
    -u BUNDLE_GEMFILE \
    -u BUNDLER_VERSION \
    -u RUBYOPT \
    BUNDLE_GEMFILE="$gemfile" \
    "$@"
}

# Track failures
FAILED_JOBS=()
OSS_DEPS_READY=false
PRO_DEPS_READY=false
JS_BUILD_RAN=false
JS_BUILD_READY=false

# Internal implementation: runs a shell command string via the shell, so
# compound commands (e.g. "cd X && make") work. Prefer the argv-based helper
# run_job_argv below — it avoids shell re-parsing and is safer with variables.
_run_job_shell() {
  local job_name="$1"
  local command="$2"
  echo -e "${BLUE}▶ Running: $job_name${NC}"
  # Keep legacy shell-command side effects, especially `cd`, scoped to the job.
  if (eval "$command"); then
    echo -e "${GREEN}✓ $job_name passed${NC}"
    echo ""
    return 0
  fi
  echo -e "${RED}✗ $job_name failed${NC}"
  echo ""
  FAILED_JOBS+=("$job_name")
  return 1
}

# run_job_argv "Job Name" cmd arg1 arg2 ...
# Runs the command as a direct argv invocation — no shell re-parsing, no
# quoting pitfalls, safe with variable expansion. Prefer this over the
# legacy single-string form whenever possible, especially with variables.
run_job_argv() {
  local job_name="$1"
  shift
  echo -e "${BLUE}▶ Running: $job_name${NC}"
  if "$@"; then
    echo -e "${GREEN}✓ $job_name passed${NC}"
    echo ""
    return 0
  fi
  echo -e "${RED}✗ $job_name failed${NC}"
  echo ""
  FAILED_JOBS+=("$job_name")
  return 1
}

# Back-compat: existing legacy callers pass one shell-command string.
# New code should use run_job_argv for safe argv execution.
run_job() {
  _run_job_shell "$@"
}

# Detect changes unless --all is specified
if [ "$RUN_ALL" = false ]; then
  echo "Analyzing optimized local CI changes since $BASE_REF..."

  # Try JSON output first (if jq is available)
  if command -v jq >/dev/null 2>&1; then
    # Get JSON output (hide from stdout). The detector also emits human-readable
    # context, so extract the JSON object as a block instead of scraping by
    # indentation.
    DETECTOR_JSON=$(
      CI_JSON_OUTPUT=1 script/ci-changes-detector "$BASE_REF" 2>&1 |
        awk '
          # Relies on the detector emitting "{" and "}" as exact standalone
          # lines (its current bare-echo/heredoc JSON format). A trailing
          # carriage return is stripped first so CRLF checkouts still match.
          # A nested or indented "{" would need brace counting instead.
          { line = $0; sub(/\r$/, "", line) }
          line == "{" && !seen_json { in_json = 1; seen_json = 1 }
          in_json { print line }
          line == "}" && in_json { in_json = 0 }
        '
    )

    if [ -n "$DETECTOR_JSON" ] && echo "$DETECTOR_JSON" | jq -e . >/dev/null 2>&1; then
      # Show human-readable output
      script/ci-changes-detector "$BASE_REF" 2>&1
      echo ""

      # Parse JSON output (robust)
      RUN_LINT=$(echo "$DETECTOR_JSON" | jq -r '.run_lint // false')
      RUN_RUBY=$(echo "$DETECTOR_JSON" | jq -r '.run_ruby_tests // false')
      RUN_JS=$(echo "$DETECTOR_JSON" | jq -r '.run_js_tests // false')
      RUN_DUMMY=$(echo "$DETECTOR_JSON" | jq -r '.run_dummy_tests // false')
      RUN_GENERATORS=$(echo "$DETECTOR_JSON" | jq -r '.run_generators // false')
      RUN_PRO_LINT=$(echo "$DETECTOR_JSON" | jq -r '.run_pro_lint // false')
      RUN_PRO_TESTS=$(echo "$DETECTOR_JSON" | jq -r '.run_pro_tests // false')
      RUN_PRO_DUMMY=$(echo "$DETECTOR_JSON" | jq -r '.run_pro_dummy_tests // false')
      DOCS_ONLY=$(echo "$DETECTOR_JSON" | jq -r '.docs_only // false')

      if [ "$DOCS_ONLY" = "true" ]; then
        # Even for docs-only changes, verify new docs have sidebar entries
        # set -euo pipefail will exit with 1 if the sidebar check fails;
        # reaching the next line means the check passed.
        run_job_argv "Docs Sidebar Check" script/check-docs-sidebar "$BASE_REF"
        echo -e "${GREEN}No further CI needed for documentation-only changes!${NC}"
        exit 0
      fi
    else
      # JSON parsing failed, fall back to text parsing
      echo -e "${YELLOW}⚠ JSON parsing failed, using text parsing (install jq for better reliability)${NC}"
      DETECTOR_OUTPUT=$(script/ci-changes-detector "$BASE_REF" 2>&1)
      echo "$DETECTOR_OUTPUT"
      echo ""

      if echo "$DETECTOR_OUTPUT" | grep -q "Documentation-only changes"; then
        # set -euo pipefail will exit with 1 if the sidebar check fails;
        # reaching the next line means the check passed.
        run_job_argv "Docs Sidebar Check" script/check-docs-sidebar "$BASE_REF"
        echo -e "${GREEN}No further CI needed for documentation-only changes!${NC}"
        exit 0
      fi

      # Parse text output (fragile fallback)
      RUN_LINT=$(echo "$DETECTOR_OUTPUT" | grep -q "✓ Lint (Ruby + JS)" && echo true || echo false)
      RUN_RUBY=$(echo "$DETECTOR_OUTPUT" | grep -q "✓ RSpec gem tests" && echo true || echo false)
      RUN_JS=$(echo "$DETECTOR_OUTPUT" | grep -q "✓ JS unit tests" && echo true || echo false)
      RUN_DUMMY=$(echo "$DETECTOR_OUTPUT" | grep -q "✓ Dummy app integration tests" && echo true || echo false)
      RUN_GENERATORS=$(echo "$DETECTOR_OUTPUT" | grep -q "✓ Generator tests" && echo true || echo false)
      RUN_PRO_LINT=$(echo "$DETECTOR_OUTPUT" | grep -q "✓ React on Rails Pro Lint" && echo true || echo false)
      RUN_PRO_TESTS=$(echo "$DETECTOR_OUTPUT" | grep -q "✓ React on Rails Pro tests" && echo true || echo false)
      RUN_PRO_DUMMY=$(echo "$DETECTOR_OUTPUT" | grep -q "✓ React on Rails Pro Dummy app integration tests" && echo true || echo false)
    fi
  else
    # jq not available, use text parsing with warning
    echo -e "${YELLOW}ℹ Note: Install 'jq' for more reliable change detection${NC}"
    DETECTOR_OUTPUT=$(script/ci-changes-detector "$BASE_REF" 2>&1)
    echo "$DETECTOR_OUTPUT"
    echo ""

    if echo "$DETECTOR_OUTPUT" | grep -q "Documentation-only changes"; then
      # set -euo pipefail will exit with 1 if the sidebar check fails;
      # reaching the next line means the check passed.
      run_job_argv "Docs Sidebar Check" script/check-docs-sidebar "$BASE_REF"
      echo -e "${GREEN}No further CI needed for documentation-only changes!${NC}"
      exit 0
    fi

    # Parse text output (fragile fallback)
    RUN_LINT=$(echo "$DETECTOR_OUTPUT" | grep -q "✓ Lint (Ruby + JS)" && echo true || echo false)
    RUN_RUBY=$(echo "$DETECTOR_OUTPUT" | grep -q "✓ RSpec gem tests" && echo true || echo false)
    RUN_JS=$(echo "$DETECTOR_OUTPUT" | grep -q "✓ JS unit tests" && echo true || echo false)
    RUN_DUMMY=$(echo "$DETECTOR_OUTPUT" | grep -q "✓ Dummy app integration tests" && echo true || echo false)
    RUN_GENERATORS=$(echo "$DETECTOR_OUTPUT" | grep -q "✓ Generator tests" && echo true || echo false)
    RUN_PRO_LINT=$(echo "$DETECTOR_OUTPUT" | grep -q "✓ React on Rails Pro Lint" && echo true || echo false)
    RUN_PRO_TESTS=$(echo "$DETECTOR_OUTPUT" | grep -q "✓ React on Rails Pro tests" && echo true || echo false)
    RUN_PRO_DUMMY=$(echo "$DETECTOR_OUTPUT" | grep -q "✓ React on Rails Pro Dummy app integration tests" && echo true || echo false)
  fi
else
  echo -e "${YELLOW}Running ALL CI checks (--all mode)${NC}"
  echo ""
  RUN_LINT=true
  RUN_RUBY=true
  RUN_JS=true
  RUN_DUMMY=true
  RUN_GENERATORS=true
  RUN_PRO_LINT=true
  RUN_PRO_TESTS=true
  RUN_PRO_DUMMY=true
fi

ensure_js_build() {
  if [ "$JS_BUILD_RAN" = true ]; then
    [ "$JS_BUILD_READY" = true ]
    return
  fi

  JS_BUILD_RAN=true
  if run_job "JavaScript Package Build" "pnpm run build"; then
    JS_BUILD_READY=true
  else
    JS_BUILD_READY=false
  fi

  [ "$JS_BUILD_READY" = true ]
}

ensure_pro_dependencies() {
  if [ "$PRO_DEPS_READY" = true ]; then
    return 0
  fi

  if [ ! -d "react_on_rails_pro" ]; then
    PRO_DEPS_READY=true
    return 0
  fi

  if [ ! -d "react_on_rails_pro/node_modules" ] || [ ! -d "react_on_rails_pro/vendor/bundle" ]; then
    echo -e "${YELLOW}Installing React on Rails Pro dependencies...${NC}"
    if ! (cd react_on_rails_pro && bundle_command "$PRO_GEMFILE" bundle install && pnpm install); then
      echo -e "${YELLOW}⚠ Pro dependencies installation failed, skipping Pro tests${NC}"
      RUN_PRO_LINT=false
      RUN_PRO_TESTS=false
      RUN_PRO_DUMMY=false
      return 1
    fi
  fi

  PRO_DEPS_READY=true
}

ensure_pro_dummy_dependencies() {
  if [ ! -d "react_on_rails_pro/spec/dummy" ]; then
    return 1
  fi

  if ! (cd "$ROOT_DIR/react_on_rails_pro/spec/dummy" && bundle_command "$PRO_DUMMY_GEMFILE" bundle check >/dev/null 2>&1); then
    echo -e "${YELLOW}Installing React on Rails Pro dummy dependencies...${NC}"
    if ! (cd "$ROOT_DIR/react_on_rails_pro/spec/dummy" && bundle_command "$PRO_DUMMY_GEMFILE" bundle install); then
      echo -e "${YELLOW}⚠ Pro dummy dependency installation failed, skipping Pro dummy test build${NC}"
      return 1
    fi
  fi
}

ensure_pro_execjs_dummy_dependencies() {
  if [ ! -d "react_on_rails_pro/spec/execjs-compatible-dummy" ]; then
    return 1
  fi

  if ! (cd "$ROOT_DIR/react_on_rails_pro/spec/execjs-compatible-dummy" && bundle_command "$PRO_EXECJS_DUMMY_GEMFILE" bundle check >/dev/null 2>&1); then
    echo -e "${YELLOW}Installing React on Rails Pro ExecJS-compatible dummy dependencies...${NC}"
    if ! (cd "$ROOT_DIR/react_on_rails_pro/spec/execjs-compatible-dummy" && bundle_command "$PRO_EXECJS_DUMMY_GEMFILE" bundle install); then
      echo -e "${YELLOW}⚠ Pro ExecJS-compatible dummy dependency installation failed, skipping its Rspack test build${NC}"
      return 1
    fi
  fi
}

ensure_oss_dependencies() {
  if [ "$OSS_DEPS_READY" = true ]; then
    return 0
  fi

  if ! (cd "$ROOT_DIR/react_on_rails" && bundle_command "$OSS_GEMFILE" bundle check >/dev/null 2>&1); then
    echo -e "${YELLOW}Installing react_on_rails Ruby dependencies...${NC}"
    if ! (cd "$ROOT_DIR/react_on_rails" && bundle_command "$OSS_GEMFILE" bundle install); then
      echo -e "${RED}✗ react_on_rails dependency installation failed${NC}"
      echo -e "${RED}Cannot proceed without dependencies. Please fix the errors above.${NC}"
      exit 1
    fi
  fi

  OSS_DEPS_READY=true
}

# Ensure dependencies are installed
if [ ! -d "node_modules" ] || [ ! -d "vendor/bundle" ]; then
  echo -e "${YELLOW}Installing dependencies...${NC}"
  if ! (bundle_command "$ROOT_GEMFILE" bundle install && pnpm install); then
    echo -e "${RED}✗ Dependency installation failed${NC}"
    echo -e "${RED}Cannot proceed without dependencies. Please fix the errors above.${NC}"
    exit 1
  fi
  echo -e "${GREEN}✓ Dependencies installed${NC}"
  echo ""
fi

# Always run the docs sidebar check (fast, no dependencies needed).
# `|| true` keeps a sidebar failure from aborting the rest of bin/ci-local via
# `set -euo pipefail` — the failure is still tracked inside run_job_argv via
# FAILED_JOBS and reported by the summary block at the end of the script.
# This is the only `run_job_*` call at the top level of the main path (all
# others are inside `if "$RUN_X" = true` gates), so adding the guard here
# gives contributors a complete failure report from a single local run.
run_job_argv "Docs Sidebar Check" script/check-docs-sidebar "$BASE_REF" || true

if [ "$RUN_RUBY" = true ] || [ "$RUN_DUMMY" = true ] || [ "$RUN_GENERATORS" = true ]; then
  ensure_oss_dependencies
fi

# Run linting
if [ "$RUN_LINT" = true ]; then
  run_job "RuboCop" "bundle_command \"$ROOT_GEMFILE\" bundle exec rubocop"
  run_job "ESLint" "pnpm run eslint --report-unused-disable-directives"
  run_job "Prettier Check" "pnpm start format.listDifferent"
  run_job "TypeScript Type Check" "pnpm run type-check"
fi

if [ "$RUN_PRO_LINT" = true ] || [ "$RUN_PRO_TESTS" = true ] || [ "$RUN_PRO_DUMMY" = true ]; then
  if [ ! -d "react_on_rails_pro" ]; then
    echo -e "${YELLOW}React on Rails Pro directory not found. Skipping Pro checks.${NC}"
    RUN_PRO_LINT=false
    RUN_PRO_TESTS=false
    RUN_PRO_DUMMY=false
  fi
fi

# Run JS unit tests
if [ "$RUN_JS" = true ]; then
  ensure_js_build || true
  run_job "JS Unit Tests" "pnpm test"
fi

if [ "$RUN_PRO_DUMMY" = true ]; then
  if [ "$FAST_MODE" = true ]; then
    echo -e "${YELLOW}Skipping React on Rails Pro dummy app integration tests in --fast mode${NC}"
    echo ""
  else
    if ensure_js_build && ensure_pro_dependencies && ensure_pro_dummy_dependencies; then
      run_job "React on Rails Pro Dummy React Resolution Check" "node script/check-single-react-resolution.mjs react_on_rails/spec/dummy react_on_rails_pro/spec/dummy"
      run_job "React on Rails Pro ExecJS Dummy React 18 Check" "node script/check-react-major-version.mjs react_on_rails_pro/spec/execjs-compatible-dummy 18"
      run_job "React on Rails Pro Dummy Generate Packs" "cd react_on_rails_pro/spec/dummy && bundle_command \"$PRO_DUMMY_GEMFILE\" bundle exec rake react_on_rails:generate_packs"
      run_job "React on Rails Pro Dummy Generated Pack Smoke" "test -s react_on_rails_pro/spec/dummy/client/app/generated/server-bundle-generated.js"
      run_job "React on Rails Pro Dummy Webpack Test Build" "cd react_on_rails_pro/spec/dummy && pnpm run build:test"
      run_job "React on Rails Pro Dummy Rspack Test Build" "cd react_on_rails_pro/spec/dummy && pnpm run build:test:rspack"
    fi

    if ensure_js_build && ensure_pro_dependencies && ensure_pro_execjs_dummy_dependencies; then
      mkdir -p "$ROOT_DIR/tmp"
      EXECJS_RSPACK_LOG="$ROOT_DIR/tmp/execjs-rspack-build.log"
      run_job "React on Rails Pro ExecJS Dummy Rspack Test Build" "cd react_on_rails_pro/spec/execjs-compatible-dummy && rm -rf public/packs-test && SHAKAPACKER_ASSETS_BUNDLER=rspack RAILS_ENV=test NODE_ENV=test ./bin/shakapacker 2>&1 | tee \"$EXECJS_RSPACK_LOG\""
      run_job "React on Rails Pro ExecJS Dummy Rspack Smoke" "test -s react_on_rails_pro/spec/execjs-compatible-dummy/public/packs-test/manifest.json && grep -qF '[Shakapacker] Completed rspack build' \"$EXECJS_RSPACK_LOG\""
    fi
  fi
fi

# Run Ruby gem tests
if [ "$RUN_RUBY" = true ]; then
  if [ "$FAST_MODE" = true ]; then
    run_job "RSpec (Gem Only - Fast)" "cd react_on_rails && bundle_command \"$OSS_GEMFILE\" bundle exec rspec spec/react_on_rails"
  else
    run_job "RSpec (Gem Only)" "cd react_on_rails && bundle_command \"$OSS_GEMFILE\" bundle exec rake run_rspec:gem"
  fi
fi

# Run dummy app tests
if [ "$RUN_DUMMY" = true ]; then
  if [ "$FAST_MODE" = true ]; then
    echo -e "${YELLOW}Skipping dummy app tests in --fast mode${NC}"
    echo ""
  else
    # Build dummy app if needed
    if [ ! -d "react_on_rails/spec/dummy/node_modules" ]; then
      echo -e "${YELLOW}Setting up dummy app...${NC}"
      if ! (cd react_on_rails/spec/dummy && pnpm install); then
        echo -e "${YELLOW}⚠ Dummy app setup failed, skipping dummy app tests${NC}"
        echo ""
      else
        run_job "Dummy App Integration Tests" "cd react_on_rails && bundle_command \"$OSS_GEMFILE\" bundle exec rake run_rspec:dummy"
      fi
    else
      run_job "Dummy App Integration Tests" "cd react_on_rails && bundle_command \"$OSS_GEMFILE\" bundle exec rake run_rspec:dummy"
    fi
  fi
fi

# Run generator tests
if [ "$RUN_GENERATORS" = true ]; then
  if [ "$FAST_MODE" = true ]; then
    echo -e "${YELLOW}Skipping generator tests in --fast mode (they are slow)${NC}"
    echo ""
  else
    run_job "Generator Tests" "cd react_on_rails && bundle_command \"$OSS_GEMFILE\" bundle exec rake run_rspec:shakapacker_examples"
  fi
fi

if [ "$RUN_PRO_LINT" = true ]; then
  if ensure_pro_dependencies; then
    run_job "React on Rails Pro RuboCop" "cd react_on_rails_pro && bundle_command \"$ROOT_GEMFILE\" bundle exec rubocop --ignore-parent-exclusion"
    run_job "React on Rails Pro RBS Validate" "cd react_on_rails_pro && bundle_command \"$PRO_GEMFILE\" bundle exec rake rbs:validate"
    run_job "React on Rails Pro TypeScript Check" "pnpm run nps check-typescript"
  fi
fi

# Run React on Rails Pro tests
if [ "$RUN_PRO_TESTS" = true ]; then
  if [ "$FAST_MODE" = true ]; then
    echo -e "${YELLOW}Skipping React on Rails Pro tests in --fast mode${NC}"
    echo ""
  elif ensure_pro_dependencies; then
    run_job "React on Rails Pro JS Tests" "cd react_on_rails_pro && pnpm run nps test"
    run_job "React on Rails Pro RSpec" "cd react_on_rails_pro && bundle_command \"$PRO_GEMFILE\" bundle exec rspec"
  fi
fi

# Summary
echo ""
echo -e "${BLUE}=== CI Summary ===${NC}"

if [ ${#FAILED_JOBS[@]} -eq 0 ]; then
  echo -e "${GREEN}All checks passed! ✓${NC}"
  exit 0
else
  echo -e "${RED}Failed jobs:${NC}"
  for job in "${FAILED_JOBS[@]}"; do
    echo -e "${RED}  ✗ $job${NC}"
  done
  echo ""
  echo -e "${YELLOW}Fix the failures above before pushing.${NC}"
  exit 1
fi
