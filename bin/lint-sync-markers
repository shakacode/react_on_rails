#!/usr/bin/env ruby
# frozen_string_literal: true

require "open3"
require "pathname"

MARKER = "MUST SYNC:"
SYNC_ROOTS = %w[
  packages/react-on-rails
  packages/react-on-rails-pro
].freeze
WHITESPACE_BYTES = [9, 10, 11, 12, 13, 32].freeze
REGEX_LITERAL_PRECEDING_PUNCTUATION_BYTES = "([{=,:;!&|?+-*~%^<>".bytes.freeze
REGEX_LITERAL_PRECEDING_KEYWORDS = %w[
  await
  case
  delete
  do
  else
  in
  instanceof
  of
  return
  throw
  typeof
  void
  yield
].freeze
COMMENT_MARKER_PATTERN = %r{\A\s*(?:(?://|\*)\s*|/\*+\s*)MUST\ SYNC:}
TARGET_PATH_PATTERN = %r{
  MUST\ SYNC:
  .*?
  (?:exists\ in|implementation\ exists\ in|with)
  \s+
  `?
  ([A-Za-z0-9_@./+\-]+)
  `?
}ix

MarkerRecord = Struct.new(
  :path,
  :line_number,
  :target_path,
  :block,
  :normalized_block,
  :block_start_line,
  :block_end_line,
  keyword_init: true
)

def repo_root
  output, status = Open3.capture2e("git", "rev-parse", "--show-toplevel")
  abort "Unable to determine repo root: #{output}" unless status.success?

  output.strip
end

def git_files
  output, status = Open3.capture2e("git", "ls-files", "-z")
  abort "Unable to list tracked files: #{output}" unless status.success?

  output.split("\0")
end

def clean_repo_path(raw_path)
  path = Pathname.new(raw_path.delete_prefix("./")).cleanpath.to_s
  return nil if path == "." || path == ".." || path.start_with?("../")

  path
end

def target_path_from(line)
  match = line.match(TARGET_PATH_PATTERN)
  return nil unless match

  clean_repo_path(match[1].sub(/[.,;:)\]]+\z/, ""))
end

def line_offsets(lines)
  offset = 0
  lines.map do |line|
    current_offset = offset
    offset += line.bytesize
    current_offset
  end
end

def sync_scope_path?(path)
  clean_path = clean_repo_path(path)
  clean_path && SYNC_ROOTS.any? { |root| clean_path == root || clean_path.start_with?("#{root}/") }
end

def initial_lexer_context
  { string_quote: nil, template_depths: [], skip_code_byte: nil }
end

def with_string_quote(context, quote_byte)
  { string_quote: quote_byte, template_depths: context[:template_depths], skip_code_byte: context[:skip_code_byte] }
end

def clear_string_quote(context)
  { string_quote: nil, template_depths: context[:template_depths], skip_code_byte: context[:skip_code_byte] }
end

def enter_template_interpolation(context, skip_code_byte)
  { string_quote: nil, template_depths: context[:template_depths] + [0], skip_code_byte: }
end

def in_template_interpolation?(context)
  context[:template_depths].any?
end

def increment_template_depth(context)
  depths = context[:template_depths]

  { string_quote: nil, template_depths: depths[0...-1] + [depths.last + 1], skip_code_byte: context[:skip_code_byte] }
end

def close_template_code_brace(context)
  depths = context[:template_depths]
  return [:code, context] if depths.empty?

  if depths.last.zero?
    return [:template, { string_quote: nil, template_depths: depths[0...-1], skip_code_byte: context[:skip_code_byte] }]
  end

  [
    :code,
    { string_quote: nil, template_depths: depths[0...-1] + [depths.last - 1], skip_code_byte: context[:skip_code_byte] }
  ]
end

def significant_code_byte?(state, context, index)
  state == :code && context[:skip_code_byte] != index
end

def advance_line_comment(index, byte, context)
  return [index, :code, context] if byte == "\n".ord

  [index, :line_comment, context]
end

def advance_block_comment(content, index, byte, context)
  next_byte = content.getbyte(index + 1)
  return [index + 1, :code, context] if byte == "*".ord && next_byte == "/".ord

  [index, :block_comment, context]
end

def advance_string(index, byte, context)
  return [index + 1, :string, context] if byte == "\\".ord
  return [index, :code, clear_string_quote(context)] if byte == context[:string_quote]

  [index, :string, context]
end

def advance_template(content, index, byte, context)
  return [index + 1, :template, context] if byte == "\\".ord

  if byte == "$".ord && content.getbyte(index + 1) == "{".ord
    return [index + 1, :code, enter_template_interpolation(context, index + 1)]
  end

  return [index, :code, context] if byte == "`".ord

  [index, :template, context]
end

def advance_regex(index, byte, context)
  return [index + 1, :regex, context] if byte == "\\".ord
  return [index, :regex_char_class, context] if byte == "[".ord
  return [index, :code, context] if byte == "/".ord || byte == "\n".ord

  [index, :regex, context]
end

def advance_regex_char_class(index, byte, context)
  return [index + 1, :regex_char_class, context] if byte == "\\".ord
  return [index, :regex, context] if byte == "]".ord || byte == "\n".ord

  [index, :regex_char_class, context]
end

def advance_comment_string_or_regex(content, index, state, context)
  byte = content.getbyte(index)

  case state
  when :line_comment
    advance_line_comment(index, byte, context)
  when :block_comment
    advance_block_comment(content, index, byte, context)
  when :string
    advance_string(index, byte, context)
  when :template
    advance_template(content, index, byte, context)
  when :regex
    advance_regex(index, byte, context)
  when :regex_char_class
    advance_regex_char_class(index, byte, context)
  else
    [index, state, context]
  end
end

def identifier_byte?(byte)
  byte == "$".ord ||
    byte == "_".ord ||
    (byte >= "0".ord && byte <= "9".ord) ||
    (byte >= "A".ord && byte <= "Z".ord) ||
    (byte >= "a".ord && byte <= "z".ord)
end

def identifier_start_byte?(byte)
  byte == "$".ord ||
    byte == "_".ord ||
    (byte >= "A".ord && byte <= "Z".ord) ||
    (byte >= "a".ord && byte <= "z".ord)
end

def skip_trailing_whitespace(content, index)
  index -= 1 while index >= 0 && WHITESPACE_BYTES.include?(content.getbyte(index))
  index
end

def skip_trailing_block_comment(content, index)
  return index unless index.positive?
  return index unless content.getbyte(index - 1) == "*".ord && content.getbyte(index) == "/".ord

  comment_start = content.rindex("/*", index - 2)
  comment_start ? comment_start - 1 : nil
end

def skip_trailing_line_comment(content, index, state_cache)
  state, = code_state_at_offset(state_cache, index)
  return index unless state == :line_comment

  line_start = content.rindex("\n", index) || -1
  cursor = line_start + 1

  while cursor <= index
    cursor_state, = code_state_at_offset(state_cache, cursor)
    if cursor_state == :line_comment && cursor.positive? &&
       content.getbyte(cursor - 1) == "/".ord && content.getbyte(cursor) == "/".ord
      return cursor - 2
    end

    cursor += 1
  end

  index
end

def previous_significant_code_index(content, index, state_cache)
  index -= 1
  loop do
    index = skip_trailing_whitespace(content, index)
    return nil if index.negative?

    next_index = skip_trailing_block_comment(content, index)
    return nil unless next_index

    if next_index != index
      index = next_index
      next
    end

    next_index = skip_trailing_line_comment(content, index, state_cache)
    if next_index != index
      index = next_index
      next
    end

    return index
  end
end

def previous_significant_token(content, index, state_cache)
  index = previous_significant_code_index(content, index, state_cache)
  return nil unless index

  byte = content.getbyte(index)
  return byte unless identifier_byte?(byte)

  token_end = index + 1
  index -= 1 while index >= 0 && identifier_byte?(content.getbyte(index))
  token_start = index + 1
  token = content.byteslice(token_start...token_end)

  identifier_start_byte?(content.getbyte(token_start)) ? token : byte
end

def regex_literal_start?(content, index, state_cache)
  previous_token = previous_significant_token(content, index, state_cache)
  return true unless previous_token

  return REGEX_LITERAL_PRECEDING_KEYWORDS.include?(previous_token) if previous_token.is_a?(String)

  REGEX_LITERAL_PRECEDING_PUNCTUATION_BYTES.include?(previous_token)
end

def comment_transition(byte, next_byte)
  return :line_comment if byte == "/".ord && next_byte == "/".ord
  return :block_comment if byte == "/".ord && next_byte == "*".ord

  nil
end

def quote_transition(byte)
  return :string if byte == "'".ord || byte == '"'.ord
  return :template if byte == "`".ord

  nil
end

def code_state_transition(content, index, state_cache)
  byte = content.getbyte(index)
  transition = comment_transition(byte, content.getbyte(index + 1))
  return transition if transition
  return :regex if byte == "/".ord && regex_literal_start?(content, index, state_cache)

  quote_transition(byte)
end

def next_code_state(content, index, state, context, state_cache = nil)
  return advance_comment_string_or_regex(content, index, state, context) unless state == :code

  byte = content.getbyte(index)
  if in_template_interpolation?(context)
    return [index, :code, increment_template_depth(context)] if byte == "{".ord

    if byte == "}".ord
      next_state, next_context = close_template_code_brace(context)
      return [index, next_state, next_context]
    end
  end

  transition = code_state_transition(content, index, state_cache)
  return [index, state, context] unless transition

  new_index = %i[line_comment block_comment].include?(transition) ? index + 1 : index
  new_context = transition == :string ? with_string_quote(context, content.getbyte(index)) : context
  [new_index, transition, new_context]
end

def build_code_state_cache(content)
  states = Array.new(content.bytesize + 1)
  index = 0
  state = :code
  context = initial_lexer_context

  while index < content.bytesize
    states[index] = [state, context]
    next_index, next_state, next_context = next_code_state(content, index, state, context, states)

    ((index + 1)..next_index).each { |skipped_index| states[skipped_index] = [next_state, next_context] }
    index = next_index + 1
    state = next_state
    context = next_context
  end

  states[content.bytesize] = [state, context]
  states
end

def code_state_at_offset(state_cache, offset)
  state_cache.fetch(offset)
end

def block_comment_line?(state_cache, offsets, line_index)
  state, = code_state_at_offset(state_cache, offsets.fetch(line_index))
  state == :block_comment
end

def marker_comment_state(state_cache, offsets, line, line_index)
  marker_column = line.byteindex(MARKER)
  return nil unless marker_column

  state, = code_state_at_offset(state_cache, offsets.fetch(line_index) + marker_column)
  state
end

def comment_marker_line?(state_cache, offsets, line, line_index)
  %i[line_comment block_comment].include?(marker_comment_state(state_cache, offsets, line, line_index))
end

def block_comment_start_line(state_cache, offsets, line_index)
  index = line_index
  index -= 1 while index.positive? && block_comment_line?(state_cache, offsets, index)
  index
end

def skip_to_block_comment_end(state_cache, lines, offsets, line_index)
  return line_index unless block_comment_line?(state_cache, offsets, line_index)

  index = line_index
  index += 1 while index + 1 < lines.length && block_comment_line?(state_cache, offsets, index + 1)
  index
end

def line_comment_only?(line)
  line.strip.start_with?("//")
end

def first_code_line_after_marker(state_cache, lines, offsets, line_index)
  index = skip_to_block_comment_end(state_cache, lines, offsets, line_index)

  index += 1
  while index < lines.length
    stripped = lines[index].strip
    break unless stripped.empty? || line_comment_only?(lines[index]) || block_comment_line?(state_cache, offsets, index)

    index += 1
  end

  index < lines.length ? index : nil
end

def code_text_on_line(content, state_cache, lines, offsets, line_index)
  index = offsets.fetch(line_index)
  end_offset = index + lines.fetch(line_index).bytesize
  state, context = code_state_at_offset(state_cache, index)
  bytes = []

  while index < end_offset
    index, state, context = next_code_state(content, index, state, context, state_cache)
    bytes << content.getbyte(index) if significant_code_byte?(state, context, index)
    index += 1
  end

  bytes.pack("C*")
end

def valid_enclosing_block_opener?(content, state_cache, lines, offsets, line_index)
  code = code_text_on_line(content, state_cache, lines, offsets, line_index).strip
  return false unless code.end_with?("{")

  code.match?(/\A(?:if\b|for\b|while\b|switch\b|try\b|catch\b|finally\b|else\b|\}\s*(?:else|catch|finally)\b)/)
end

def immediate_enclosing_block_line(content, state_cache, lines, offsets, line_index)
  index = line_index - 1
  index -= 1 while index >= 0 && lines[index].strip.empty?
  return nil if index.negative?
  return nil if block_comment_line?(state_cache, offsets, index) || line_comment_only?(lines[index])
  return nil unless valid_enclosing_block_opener?(content, state_cache, lines, offsets, index)
  return nil unless find_code_brace_on_line(content, state_cache, lines, offsets, index)

  index
end

def synchronized_block_start_line(marker_context, line, line_index)
  content = marker_context.fetch(:content)
  state_cache = marker_context.fetch(:state_cache)
  lines = marker_context.fetch(:lines)
  offsets = marker_context.fetch(:offsets)

  if marker_comment_state(state_cache, offsets, line, line_index) == :block_comment
    comment_start_line = block_comment_start_line(state_cache, offsets, line_index)
    guarded_start_line = immediate_enclosing_block_line(content, state_cache, lines, offsets, comment_start_line)

    return guarded_start_line if guarded_start_line

    return first_code_line_after_marker(state_cache, lines, offsets, line_index)
  end

  immediate_enclosing_block_line(content, state_cache, lines, offsets, line_index) ||
    first_code_line_after_marker(state_cache, lines, offsets, line_index)
end

def find_code_brace_on_line(content, state_cache, lines, offsets, line_index)
  index = offsets.fetch(line_index)
  end_offset = index + lines.fetch(line_index).bytesize
  state, context = code_state_at_offset(state_cache, index)
  brace_index = nil

  while index < end_offset
    index, state, context = next_code_state(content, index, state, context, state_cache)
    # Use the last significant { on the line; in `if (fn({})) {`, the block opener is last.
    brace_index = index if significant_code_byte?(state, context, index) && content.getbyte(index) == "{".ord
    index += 1
  end

  brace_index
end

def find_matching_brace(content, state_cache, open_index)
  index = open_index
  state, context = code_state_at_offset(state_cache, open_index)
  depth = 0

  while index < content.bytesize
    next_index, state, context = next_code_state(content, index, state, context, state_cache)
    index = next_index
    byte = content.getbyte(index)

    if significant_code_byte?(state, context, index) && byte == "{".ord
      depth += 1
    elsif significant_code_byte?(state, context, index) && byte == "}".ord
      depth -= 1
      return index if depth.zero?
    end

    index += 1
  end

  nil
end

def line_index_for_offset(content, offset)
  content.byteslice(0...offset).count("\n")
end

def extract_sync_block(content, state_cache, lines, offsets, start_line)
  start_offset = offsets.fetch(start_line)
  open_index = find_code_brace_on_line(content, state_cache, lines, offsets, start_line)
  return [nil, nil, nil] unless open_index

  close_index = find_matching_brace(content, state_cache, open_index)
  return [nil, nil, nil] unless close_index

  end_line = line_index_for_offset(content, close_index)
  end_offset = offsets.fetch(end_line) + lines.fetch(end_line).bytesize

  [content.byteslice(start_offset...end_offset), start_line, end_line]
end

def common_indent_for(lines)
  non_empty_lines = lines.reject(&:empty?)
  non_empty_lines.map { |line| line[/\A[ \t]*/].bytesize }.min || 0
end

def trim_blank_edges(lines)
  lines.shift while lines.first == ""
  lines.pop while lines.last == ""
  lines
end

def normalize_block(block)
  lines = block.lines.map(&:rstrip).grep_v(COMMENT_MARKER_PATTERN)
  lines = trim_blank_edges(lines)
  common_indent = common_indent_for(lines)

  lines.map { |line| line.sub(/\A[ \t]{0,#{common_indent}}/, "") }.join("\n")
end

def marker_record_from_line(marker_context, line, index)
  path = marker_context.fetch(:path)
  content = marker_context.fetch(:content)
  state_cache = marker_context.fetch(:state_cache)
  lines = marker_context.fetch(:lines)
  offsets = marker_context.fetch(:offsets)
  errors = marker_context.fetch(:errors)

  target_path = target_path_from(line)
  unless target_path
    errors << "#{path}:#{index + 1}: unable to parse sync target path"
    return nil
  end

  block_start_line = synchronized_block_start_line(marker_context, line, index)
  unless block_start_line
    errors << "#{path}:#{index + 1}: no synchronized block found after marker"
    return nil
  end

  block, start_line, end_line = extract_sync_block(content, state_cache, lines, offsets, block_start_line)
  unless block
    errors << "#{path}:#{index + 1}: unable to extract synchronized block"
    return nil
  end

  MarkerRecord.new(
    path:,
    line_number: index + 1,
    target_path:,
    block:,
    normalized_block: normalize_block(block),
    block_start_line: start_line + 1,
    block_end_line: end_line + 1
  )
end

def parse_markers(path, content)
  lines = content.lines
  offsets = line_offsets(lines)
  state_cache = build_code_state_cache(content)
  records = []
  errors = []
  marker_context = { path:, content:, state_cache:, lines:, offsets:, errors: }

  lines.each_with_index do |line, index|
    next unless line.match?(COMMENT_MARKER_PATTERN)
    next unless comment_marker_line?(state_cache, offsets, line, index)

    record = marker_record_from_line(marker_context, line, index)
    records << record if record
  end

  [records, errors]
end

def first_difference(left, right)
  left_lines = left.lines
  right_lines = right.lines
  max = [left_lines.length, right_lines.length].max

  max.times do |index|
    next if left_lines[index] == right_lines[index]

    return [
      index + 1,
      (left_lines[index] || "<missing>\n").chomp,
      (right_lines[index] || "<missing>\n").chomp
    ]
  end

  nil
end

def drift_message(record, candidate)
  diff = first_difference(record.normalized_block, candidate.normalized_block)
  detail = if diff
             line_number, left, right = diff
             "\n  first differing normalized line #{line_number}:" \
               "\n    #{record.path}: #{left}" \
               "\n    #{candidate.path}: #{right}"
           else
             ""
           end

  "#{record.path}:#{record.line_number} block #{record.block_start_line}-#{record.block_end_line} " \
    "does not match #{candidate.path}:#{candidate.line_number} " \
    "block #{candidate.block_start_line}-#{candidate.block_end_line}#{detail}"
end

ROOT = repo_root
Dir.chdir(ROOT)

records = []
errors = []

git_files.sort.each do |path|
  next unless File.file?(path)
  next unless sync_scope_path?(path)

  content = File.binread(path)
  next unless content.include?(MARKER)

  content.force_encoding(Encoding::UTF_8)
  unless content.valid_encoding?
    errors << "#{path}: contains #{MARKER.inspect} but is not valid UTF-8"
    next
  end

  file_records, file_errors = parse_markers(path, content)
  records.concat(file_records)
  errors.concat(file_errors)
end

records_by_path = records.group_by(&:path)
drift_pair_keys = {}
records.each do |record|
  unless sync_scope_path?(record.target_path)
    errors << "#{record.path}:#{record.line_number}: target #{record.target_path} is outside sync marker scope"
    next
  end

  if record.target_path == record.path
    errors << "#{record.path}:#{record.line_number}: target #{record.target_path} cannot be the same file"
    next
  end

  unless File.file?(record.target_path)
    errors << "#{record.path}:#{record.line_number}: target #{record.target_path} does not exist"
    next
  end

  candidates = records_by_path.fetch(record.target_path, []).select { |candidate| candidate.target_path == record.path }
  if candidates.empty?
    errors << "#{record.path}:#{record.line_number}: target #{record.target_path} has no reciprocal #{MARKER} marker"
    next
  end

  next if candidates.any? { |candidate| candidate.normalized_block == record.normalized_block }

  candidate = candidates.first
  pair_key = [[record.path, record.line_number], [candidate.path, candidate.line_number]].sort
  next if drift_pair_keys[pair_key]

  drift_pair_keys[pair_key] = true
  errors << drift_message(record, candidate)
end

if errors.any?
  warn "Sync marker lint failed:"
  errors.uniq.each { |error| warn "  - #{error}" }
  exit 1
end

pair_count = records.map { |record| [record.path, record.target_path].sort }.uniq.length
puts "Checked #{records.length} #{MARKER} markers across #{pair_count} synchronized pairs."
