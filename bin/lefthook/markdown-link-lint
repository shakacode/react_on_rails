#!/usr/bin/env bash
# Check links in changed Markdown files with lychee
set -euo pipefail
source "$(dirname "$0")/ensure-mise"

CONTEXT="${1:-staged}"
files="$(bin/lefthook/get-changed-files "$CONTEXT" '\.md$')"

if [ -z "$files" ]; then
  echo "✅ No Markdown files to check with lychee"
  exit 0
fi

echo "🔗 Lychee on $CONTEXT Markdown files:"
printf "  %s\n" $files

lychee --config .lychee.toml $files

echo "✅ Markdown link checks passed"
