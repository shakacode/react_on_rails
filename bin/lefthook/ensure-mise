#!/usr/bin/env bash
# Ensure mise-managed tools are on PATH for lefthook scripts.
# Safety net for environments where shell startup files are not loaded.

MISE_BIN="$(command -v mise 2>/dev/null || true)"
if [ -z "$MISE_BIN" ] && [ -x /opt/homebrew/bin/mise ]; then
  MISE_BIN="/opt/homebrew/bin/mise"
fi

if [ -z "$MISE_BIN" ]; then
  return 0 2>/dev/null || true
fi

# Initialize shell shims for non-interactive contexts.
eval "$(env -u MISE_SHELL "$MISE_BIN" activate bash --shims)"
