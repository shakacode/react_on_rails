#!/usr/bin/env bash
# Auto-fix Ruby files using rake autofix
set -euo pipefail
source "$(dirname "$0")/ensure-mise"

CONTEXT="${1:-staged}"
files="$(bin/lefthook/get-changed-files "$CONTEXT" '\.(rb|rake|ru)$')"

if [ -z "$files" ]; then
  echo "✅ No Ruby files to autofix"
  exit 0
fi

if [ "$CONTEXT" = "all-changed" ]; then
  echo "🎨 Autofix on all changed Ruby files:"
else
  echo "🎨 Autofix on $CONTEXT Ruby files:"
fi
printf "  %s\n" $files

# Run RuboCop only on changed files (not the full rake autofix)
bundle exec rubocop -A --force-exclusion -- $files

echo "✅ Auto-fix complete (fixed files staged automatically)"
