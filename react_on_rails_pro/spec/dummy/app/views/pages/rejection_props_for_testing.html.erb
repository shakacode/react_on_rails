<h1>Prop Rejection Test</h1>
<p>Tests that Rails can reject a pulled prop and React shows an error boundary.</p>

<%= stream_react_component_with_async_props(
  "LazyPropRejectionComponent",
  props: {},
  push_props: []
) do |emit|
  while (prop_name = emit.pull_requests.dequeue)
    case prop_name
    when "allowedData"
      emit.call("allowedData", ["Item A", "Item B", "Item C"])
    when "forbiddenData"
      emit.reject("forbiddenData", "Access denied: insufficient permissions")
    else
      emit.reject(prop_name, "Unknown prop: #{prop_name}")
    end
  end
end %>
