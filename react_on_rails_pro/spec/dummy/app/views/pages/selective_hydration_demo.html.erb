<%
  # Parse sectionDelays from query params if provided (used by rake task)
  # Format: ?section_delays=[0,5000,10000,15000]
  section_delays = []
  if params[:section_delays].present?
    begin
      section_delays = JSON.parse(params[:section_delays])
    rescue JSON::ParserError
      section_delays = []
    end
  end
%>
<%= stream_react_component("SelectiveHydrationDemo",
    props: {
      siteName: "TechBlog",
      articleTitle: "Understanding Selective Hydration in React",
      articleContent: "Selective hydration allows React to hydrate parts of your page independently, improving time-to-interactive.",
      categories: ["React", "Rails", "JavaScript", "Ruby", "TypeScript"],
      sectionDelays: section_delays
    },
    trace: true,
    id: "SelectiveHydrationDemo-react-component-0") %>

<style>
  body {
    margin: 0;
    padding: 0;
  }
</style>
