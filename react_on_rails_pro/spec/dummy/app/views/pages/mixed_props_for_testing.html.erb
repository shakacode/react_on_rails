<h1>Mixed Props Test (Push + Pull)</h1>
<p>"stats" is pushed eagerly, "recommendations" and "relatedPosts" are pulled lazily.</p>

<%= stream_react_component_with_async_props(
  "MixedPropsComponent",
  props: { pageTitle: "Mixed Props Demo" },
  push_props: %w[stats]
) do |emit|
  # Push stats eagerly — this is declared in push_props so Node won't pull it
  emit.call("stats", { views: 1500, likes: 42 })

  # Handle pull requests from React for remaining props
  while (prop_name = emit.pull_requests.dequeue)
    case prop_name
    when "recommendations"
      emit.call("recommendations", ["Learn Ruby", "Try React 19", "Read DDIA"])
    when "relatedPosts"
      emit.call("relatedPosts", [
        { id: 1, title: "Getting Started with RSC" },
        { id: 2, title: "Streaming SSR Deep Dive" }
      ])
    else
      emit.reject(prop_name, "Unknown prop: #{prop_name}")
    end
  end
end %>
