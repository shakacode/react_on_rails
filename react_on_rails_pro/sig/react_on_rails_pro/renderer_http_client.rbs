module ReactOnRailsPro
  class RendererHttpClient
    class Error < StandardError
    end

    class TimeoutError < Error
    end

    class ConnectionError < Error
    end

    class HTTPError < Error
      attr_reader response: Response

      def initialize: (Response response) -> void
    end

    CONNECTION_ERRORS: Array[Class]

    STALE_KEEPALIVE_RETRY_ERRORS: Array[Class]

    SCHEDULER_CLIENTS_KEY: Symbol

    class ConnectTimeoutWrapper
      def initialize: (connect_timeout: Numeric?, ?read_timeout: Numeric?) -> void

      def connect: (untyped remote_address, **untyped options) ?{ (untyped) -> untyped } -> untyped
    end

    class BufferedResponseBody
      def initialize: (Array[String] chunks) -> void

      def each: () { (String) -> untyped } -> untyped

      def close: () -> nil
    end

    class MultipartFileBody
      CHUNK_SIZE: Integer

      def initialize: (untyped body) -> void

      def read: () -> String?

      def close: () -> nil
    end

    class MultipartBody
      def <<: (untyped chunk) -> untyped

      def read: () -> String?

      def close: (?StandardError? error) -> untyped
    end

    class PersistentThreadClient
      def initialize: (endpoint: untyped, protocol: untyped, pool_limit: Integer?) -> void

      def post: (String path, headers: untyped, body: untyped) -> untyped

      def get: (String path, headers: untyped) -> untyped

      def close: () -> nil

      def alive?: () -> bool
    end

    class Response
      attr_reader status: Integer?

      def initialize: (?status: Integer?, ?body: Array[String] | String?, ?error: StandardError?) ?{
        (untyped, untyped) -> untyped
      } -> void

      def body: () -> String

      def error?: () -> bool

      def each: () -> Enumerator[String, void]
              | () { (String) -> untyped } -> untyped

    end

    def self.get: (String url, connect_timeout: Numeric?, read_timeout: Numeric?) -> Response

    def self.split_url: (String url) -> [String, String]

    def self.client_generation: () -> Integer

    def self.bump_client_generation: () -> Integer

    def self.build_multipart_body: (
      Hash[untyped, untyped] form,
      ?boundary: String
    ) -> [Array[[String, String]], MultipartBody]

    def self.build_form_body: (Hash[untyped, untyped] form) -> [Array[[String, String]], MultipartBody | String]

    def initialize: (
      origin: String,
      pool_size: Integer?,
      connect_timeout: Numeric?,
      read_timeout: Numeric?,
      ?force_http2: bool
    ) -> void

    def post: (
      String path,
      ?form: Hash[untyped, untyped]?,
      ?json: Hash[untyped, untyped]?,
      ?stream: bool
    ) -> Response

    def get: (String path) -> Response

    def post_bidi: (String path, headers: Array[[String, String]]) -> [untyped, Response]

    def close: () -> nil
  end
end
